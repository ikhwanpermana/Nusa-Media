---
// src/pages/index.astro
export const prerender = false;

import { supabase } from '../lib/supabase'; 
import '../styles/global.css';

const { data: daftarBerita, error } = await supabase
  .from('berita')
  .select('*')
  .order('created_at', { ascending: false });

const beritaSedia = daftarBerita || [];

// 🔥 PERBAIKAN SINTAKSIS: Ambil indeks ke-0 untuk berita utama, sisanya untuk list bawah
const beritaUtama = beritaSedia.length > 0 ? beritaSedia[0] : null;
const beritaSisa = beritaSedia.length > 1 ? beritaSedia.slice(1) : [];

const judulSEO = "Nusa Media | Portal Berita Terkini & Mendalam";
const deskripsiSEO = "Platform media digital independen yang menyajikan jurnalisme investigatif, akurat, dan real-time.";
---

<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{judulSEO}</title>
    <meta name="description" content={deskripsiSEO} />
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,700;1,600&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#fcfcfc] text-slate-900 min-h-screen antialiased selection:bg-red-500 selection:text-white" style="font-family: 'Plus Jakarta Sans', sans-serif;">
    
    <header class="bg-white/80 backdrop-blur-md border-b border-slate-100 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-extrabold tracking-tight text-slate-900 uppercase">
          NUSA<span class="text-red-600">.MEDIA</span>
        </a>
        <div class="flex items-center gap-4">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-600"></span>
          </span>
          <span class="text-xs font-bold text-slate-500 uppercase tracking-widest hidden sm:inline">Live Updates</span>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
      
      {error && (
        <div class="bg-red-50 border-l-4 border-red-600 text-red-900 p-4 rounded-r-xl mb-10 text-sm font-medium">
          Gangguan Sinkronisasi Sistem: {error.message}
        </div>
      )}

      <!-- SECTION 1: HERO / BERITA UTAMA -->
      {beritaUtama && (
        <section class="mb-16">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition duration-300 p-6 sm:p-8">
            <div class="lg:col-span-7 aspect-[16/10] bg-slate-100 rounded-xl overflow-hidden relative group">
              <img 
                src={beritaUtama.gambar_url || "https://unsplash.com"} 
                alt={beritaUtama.judul} 
                class="w-full h-full object-cover transition duration-700 group-hover:scale-102"
              />
            </div>
            <div class="lg:col-span-5 flex flex-col justify-center">
              <span class="text-xs font-extrabold uppercase tracking-widest text-red-600 mb-3 block">
                {beritaUtama.kategori || 'Sorotan utama'}
              </span>
              <h2 class="text-2xl sm:text-4xl font-bold text-slate-950 leading-tight mb-4 tracking-tight hover:text-red-600 transition duration-200" style="font-family: 'Playfair Display', serif;">
                <a href={`/berita/${beritaUtama.slug || beritaUtama.id}`}>{beritaUtama.judul}</a>
              </h2>
              <p class="text-slate-600 text-sm sm:text-base leading-relaxed mb-6 line-clamp-3">
                {String(beritaUtama.ringkasan || beritaUtama.isi_konten || '').replace(/<[^>]*>/g, '')}
              </p>
              <div>
                <a href={`/berita/${beritaUtama.slug || beritaUtama.id}`} class="inline-flex items-center gap-2 text-sm font-bold text-slate-900 hover:text-red-600 group transition">
                  Analisis Selengkapnya 
                  <span class="transform group-hover:translate-x-1 transition duration-200">→</span>
                </a>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- SECTION 2: GRID BERITA TERBARU -->
      <section>
        <div class="flex items-center justify-between border-b border-slate-200 pb-4 mb-8">
          <h3 class="text-lg font-extrabold text-slate-900 uppercase tracking-wider">Arsip Laporan Terbaru</h3>
          <div class="h-1 w-12 bg-red-600 rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {beritaSisa.map((item) => (
            <article class="group flex flex-col bg-white border border-slate-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1">
              <div class="aspect-[16/10] bg-slate-50 overflow-hidden relative">
                <img 
                  src={item.gambar_url || "https://unsplash.com"} 
                  alt={item.judul} 
                  class="w-full h-full object-cover transition duration-500 group-hover:scale-105"
                />
              </div>
              
              <div class="p-6 flex flex-col flex-1">
                <span class="text-[10px] font-black uppercase tracking-widest text-red-600 mb-2.5 block">
                  {item.kategori || 'Fokus'}
                </span>
                
                <h4 class="text-lg font-bold text-slate-950 leading-snug mb-3 line-clamp-2 group-hover:text-red-600 transition duration-200">
                  <a href={`/berita/${item.slug || item.id}`}>{item.judul}</a>
                </h4>
                
                <p class="text-sm text-slate-500 leading-relaxed mb-5 line-clamp-3 flex-1">
                  {String(item.ringkasan || item.isi_konten || '').replace(/<[^>]*>/g, '')}
                </p>
                
                <div class="pt-4 border-t border-slate-50">
                  <a 
                    href={`/berita/${item.slug || item.id}`} 
                    class="text-xs font-extrabold text-slate-900 group-hover:text-red-600 inline-flex items-center gap-1 transition"
                  >
                    Baca Artikel <span>→</span>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <footer class="bg-slate-950 text-slate-400 py-12 mt-20 border-t border-slate-900">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row justify-between items-center gap-6">
        <p class="text-xs font-semibold tracking-wider uppercase text-slate-500">© 2026 Nusa Media. Hak Cipta Dilindungi.</p>
        <div class="flex gap-6 text-xs font-bold uppercase tracking-widest">
          <a href="#" class="hover:text-white transition">Redaksi</a>
          <a href="#" class="hover:text-white transition">Pedoman Media</a>
        </div>
      </div>
    </footer>
  </body>
</html>
