---
// TENTU KAN DI BAGIAN PALING ATAS FILE src/pages/index.astro
import { supabase } from '../lib/supabase';

// ⚙️ KONFIGURASI GITHUB CADANGAN (FALLBACK)
const GITHUB_USERNAME = "ikhwanpermana"; 
const REPO_NAME = "Nusa-Media";          
const FILE_PATH = "data/berita.json";    

let postingan = [];
let sumberData = "Supabase Database";
let errorSistem = null;

// 1. AMBIL DATA DARI SUPABASE (Target utama harus nama tabel yang valid)
try {
  const { data: dataSupabase, error: errorSupabase } = await supabase
    .from('berita') // 🔥 PASTIKAN INI TULISANNYA 'berita' BUKAN 'artikel'
    .select('*')
    .order('created_at', { ascending: false });

  if (errorSupabase) throw errorSupabase;

  if (dataSupabase && dataSupabase.length > 0) {
    postingan = dataSupabase;
    sumberData = "Supabase Database (Utama)";
  } else {
    throw new Error("Tabel berita di Supabase masih kosong / tidak ada data.");
  }

} catch (mainError: any) {
  // Jalur cadangan mengambil dari repositori GitHub jika Supabase timeout/error
  try {
    const githubResponse = await fetch(
      `https://githubusercontent.com{GITHUB_USERNAME}/${REPO_NAME}/main/${FILE_PATH}`
    );
    if (githubResponse.ok) {
      postingan = await githubResponse.json();
      sumberData = "GitHub Repository (Cadangan)";
    } else {
      throw new Error("GitHub Fallback juga kosong.");
    }
  } catch (fallbackError: any) {
    errorSistem = `Koneksi database kosong. Supabase: ${mainError.message}`;
  }
}

// 2. AMBIL DATA IKLAN
let iklanSidebarAtas = null;
let iklanTengah = null;
try {
  const { data: adSidebar } = await supabase.from('iklan').select('*').eq('posisi', 'sidebar_atas').eq('status', 'aktif').order('created_at', { ascending: false }).limit(1).maybeSingle();
  const { data: adTengah } = await supabase.from('iklan').select('*').eq('posisi', 'detail_atas').eq('status', 'aktif').order('created_at', { ascending: false }).limit(1).maybeSingle();
  iklanSidebarAtas = adSidebar;
  iklanTengah = adTengah;
} catch (e) {}

const semuaBeritaTersedia = postingan && postingan.length > 0 ? postingan : [];
---
