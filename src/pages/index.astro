---
// src/pages/index.astro
import { supabase } from '../lib/supabase';
// 🔥 PERBAIKAN 1: Membetulkan jalur impor agar pas membaca folder styles dari halaman utama
import '../styles/global.css'; 

// Mengaktifkan mode statis (Astro akan build ulang otomatis saat webhook Supabase terpicu)
export const prerender = true;

// AMBIL DATA REAL-TIME DARI SUPABASE
const { data: beritaSupabase, error } = await supabase
  .from('berita')
  .select('*')
  .order('created_at', { ascending: false });

const semuaBeritaTersedia = beritaSupabase || [];

if (error) {
  console.error("Gagal mengambil data dari Supabase di Beranda:", error.message);
}
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nusa-Media | Portal Berita Multi-Sistem Hybrid</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://w3.org viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📰</text></svg>">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-gray-100 text-gray-900 min-h-screen" style="font-family: 'Roboto', sans-serif;">

    <!-- Top Bar Info -->
    <div class="bg-red-700 text-white text-xs py-2">
      <div class="max-w-6xl mx-auto px-4 flex justify-between items-center">
        <div>📍 Regional Pembaruan Nusantara</div>
        <div class="flex items-center gap-4">
          <span class="bg-white/20 px-2 py-0.5 rounded text-[10px] uppercase font-bold tracking-wide">Sumber: Supabase Data Engine</span>
          <div class="flex items-center gap-1.5">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            <span>Total Berita: {semuaBeritaTersedia.length}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Header Branding -->
    <header class="bg-slate-900 text-white border-b-4 border-red-600 shadow-md">
      <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <div>
          <h1 class="text-4xl font-black tracking-tight text-white flex items-center gap-1">
            <a href="/">NUSA<span class="text-red-500">MEDIA</span><span class="text-xs text-gray-400 font-normal border-l border-gray-600 pl-2">ONLINE</span></a>
          </h1>
          <p class="text-xs text-gray-400 mt-0.5">Media Informasi Terpercaya • Berbasis Sumber Akurat</p>
        </div>
        <div class="w-full md:w-96 bg-red-50 border border-red-200 text-red-700 font-bold p-3 text-center text-xs rounded shadow-sm">
          Space Iklan Ucapan Selamat & Sukses Instansi / Perorangan
        </div>
      </div>
    </header>

    <!-- KATEGORI MENU BAR (BARU & INTERAKTIF) -->
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-xs">
      <div class="max-w-6xl mx-auto px-4 py-3 overflow-x-auto flex gap-2 no-scrollbar">
        <button data-filter="semua" class="btn-filter text-xs font-black uppercase tracking-wider px-4 py-2 rounded-lg bg-red-600 text-white shadow-xs transition whitespace-nowrap">
          🌐 Semua
        </button>
        <button data-filter="Politik & Ekonomi" class="btn-filter text-xs font-black uppercase tracking-wider px-4 py-2 rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 transition whitespace-nowrap">
          ⚖️ Politik & Ekonomi
        </button>
        <button data-filter="Teknologi Digital" class="btn-filter text-xs font-black uppercase tracking-wider px-4 py-2 rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 transition whitespace-nowrap">
          💻 Teknologi Digital
        </button>
        <button data-filter="Nusantara Global" class="btn-filter text-xs font-black uppercase tracking-wider px-4 py-2 rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 transition whitespace-nowrap">
          🇲🇨 Nusantara Global
        </button>
        <button data-filter="Olahraga & Gaya Hidup" class="btn-filter text-xs font-black uppercase tracking-wider px-4 py-2 rounded-lg bg-gray-100 text-gray-600 hover:bg-gray-200 transition whitespace-nowrap">
          ⚽ Olahraga & Gaya Hidup
        </button>
      </div>
    </nav>

    <!-- Konten Utama -->
    <main class="max-w-6xl mx-auto px-4 py-6">
      <div class="space-y-4">
        <div class="border-b-2 border-slate-800 pb-1 flex justify-between items-center">
          <h2 id="judul-arsip" class="bg-slate-800 text-white px-3 py-1 text-xs font-bold uppercase tracking-wider inline-block">Arsip Berita: Semua</h2>
        </div>
        
        {semuaBeritaTersedia.length > 0 ? (
          <div id="wadah-berita" class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {semuaBeritaTersedia.map((berita) => {
              const linkDetail = berita.slug ? `/berita/${berita.slug}` : `/berita/${berita.id}`;
              const gambarBerita = berita.gambar_url || "https://unsplash.com";
              const kategoriTeks = (berita.kategori || 'Fokus').trim();

              return (
                <article data-category={kategoriTeks} class="kartu-berita bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden flex flex-col justify-between hover:shadow-md transition group">
                  <div>
                    <!-- Gambar Bisa Diklik -->
                    <a href={linkDetail} class="block h-44 bg-slate-200 overflow-hidden relative">
                      <img 
                        src={gambarBerita} 
                        alt={berita.judul} 
                        class="w-full h-full object-cover group-hover:scale-105 transition duration-300" 
                      />
                      <span class="absolute top-3 left-3 bg-red-600 text-white text-[9px] font-black uppercase px-2 py-0.5 rounded tracking-wide-label">
                        {kategoriTeks}
                      </span>
                    </a>
                    <div class="p-4 space-y-3">
                      <h3 class="font-bold text-gray-900 leading-tight text-lg line-clamp-2 hover:text-red-600">
                        <a href={linkDetail}>{berita.judul}</a>
                      </h3>
                      <p class="text-xs text-gray-600 mt-3 border-t pt-3 leading-relaxed text-justify line-clamp-4">
                        {berita.ringkasan || berita.isi_konten}
                      </p>
                      
                      <!-- Tombol Baca Selengkapnya -->
                      <div class="pt-1">
                        <a href={linkDetail} class="inline-flex items-center text-xs font-black text-red-600 hover:text-red-700 hover:underline uppercase tracking-wider gap-1 group/btn">
                          Baca Selengkapnya 
                          <span class="inline-block transition-transform duration-200 group-hover/btn:translate-x-1">→</span>
                        </a>
                      </div>
                    </div>
                  </div>
                  <div class="p-4 bg-gray-50 border-t border-gray-100 flex justify-between items-center text-[11px] text-gray-400">
                    <span>Penulis: <strong class="text-gray-600">{berita.penulis || 'Redaksi'}</strong></span>
                    <span>{berita.created_at ? new Date(berita.created_at).toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric'}) : ''}</span>
                  </div>
                </article>
              );
            })}
          </div>
        ) : (
          <p class="text-sm text-gray-500 italic text-center p-8 bg-white rounded">Belum ada arsip berita yang tersedia di cloud database.</p>
        )}
      </div>
    </main>

    <!-- FOOTER BAR (DIPERBAIKI) -->
    <footer class="bg-slate-900 text-gray-400 text-xs py-6 mt-12 space-y-3">
      <div class="flex justify-center gap-4 text-gray-500">
        <a href="/syarat" class="hover:text-red-500 transition">Syarat & Ketentuan</a>
        <span>•</span>
        <a href="/" class="hover:text-red-500 transition">Hubungi Kami</a>
      </div>
      <p>© Nusa-Media Online. All Rights Reserved.</p>
    </footer>

    <!-- 🔥 PERBAIKAN 2: Menyisipkan kembali naskah skrip penyaring berita sisi klien yang hilang -->
    <script is:inline>
      const tombolFilter = document.querySelectorAll('.btn-filter');
      const daftarKartuBerita = document.querySelectorAll('.kartu-berita');
      const labelJudulArsip = document.getElementById('judul-arsip');

      tombolFilter.forEach(tombol => {
        tombol.addEventListener('click', () => {
          const kategoriTarget = tombol.getAttribute('data-filter');

          // A. Ubah Gaya Warna Aktif Tombol Kategori
          tombolFilter.forEach(b => {
            b.classList.remove('bg-red-600', 'text-white', 'shadow-xs');
            b.classList.add('bg-gray-100', 'text-gray-600');
          });
          tombol.classList.remove('bg-gray-100', 'text-gray-600');
          tombol.classList.add('bg-red-600', 'text-white', 'shadow-xs');

          // B. Ubah Judul Header Kelompok Arsip Liputan
          if (labelJudulArsip) {
            labelJudulArsip.textContent = `Arsip Berita: ${kategoriTarget === 'semua' ? 'Semua' : kategoriTarget}`;
          }

          // C. Saring Sembunyikan/Munculkan Kotak Kartu Berita secara Instan
          daftarKartuBerita.forEach(kartu => {
            const kategoriKartu = kartu.getAttribute('data-category');
            if (kategoriTarget === 'semua' || kategoriKartu === kategoriTarget) {
              kartu.style.display = 'flex';
            } else {
              kartu.style.display = 'none';
            }
          });
        });
      });
    </script>
  </body>
</html>
