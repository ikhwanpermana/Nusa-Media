---
import { supabase } from '../lib/supabase';

// ⚙️ KONFIGURASI GITHUB CADANGAN (FALLBACK)
const GITHUB_USERNAME = "ikhwanpermana"; 
const REPO_NAME = "Nusa-Media";          
const FILE_PATH = "data/berita.json";    

let postingan = [];
let sumberData = "Supabase Database";
let errorSistem = null;

// 1. STRATEGI UTAMA: Ambil Data dari Supabase dengan Batas Waktu 4 Detik
try {
  const pengontrolWaktu = new AbortController();
  const idWaktu = setTimeout(() => pengontrolWaktu.abort(), 4000);

  const { data: dataSupabase, error: errorSupabase } = await supabase
    .from('artikel')
    .select('*')
    .order('created_at', { ascending: false })
    .abortSignal(pengontrolWaktu.signal);

  clearTimeout(idWaktu);

  if (errorSupabase || !dataSupabase || dataSupabase.length === 0) {
    throw new Error(errorSupabase?.message || "Tabel Supabase kosong, beralih ke cadangan.");
  }
  
  postingan = dataSupabase;
  sumberData = "Supabase Database (Utama)";

} catch (mainError: any) {
  try {
    const pengontrolWaktuGh = new AbortController();
    const idWaktuGh = setTimeout(() => pengontrolWaktuGh.abort(), 4000);

    const githubResponse = await fetch(
      `https://githubusercontent.com{GITHUB_USERNAME}/${REPO_NAME}/main/${FILE_PATH}`,
      { 
        headers: { 'Accept': 'application/vnd.github.v3.raw' },
        signal: pengontrolWaktuGh.signal
      }
    );

    clearTimeout(idWaktuGh);

    if (!githubResponse.ok) {
      throw new Error(`GitHub API juga gagal (Status: ${githubResponse.status})`);
    }

    const dataJson = await githubResponse.json();
    postingan = dataJson.sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());
    sumberData = "GitHub Repository (Cadangan)";
    
  } catch (fallbackError: any) {
    errorSistem = `Kedua sistem lambat/gagal merespons. Supabase: ${mainError.message} | GitHub: ${fallbackError.message}`;
  }
}

// 2. AMBIL DATA IKLAN
let iklanSidebarAtas = null;
let iklanTengah = null;

try {
  const { data: adSidebar } = await supabase.from('iklan').select('*').eq('posisi', 'sidebar_atas').eq('status', 'aktif').order('created_at', { ascending: false }).limit(1).maybeSingle();
  const { data: adTengah } = await supabase.from('iklan').select('*').eq('posisi', 'detail_atas').eq('status', 'aktif').order('created_at', { ascending: false }).limit(1).maybeSingle();
  iklanSidebarAtas = adSidebar;
  iklanTengah = adTengah;
} catch (e) {
  // Offline fallback aman
}

// ✨ MODIFIKASI LOGIKA: Mengalirkan seluruh array postingan tanpa pemotongan slice()
const semuaBeritaTersedia = postingan && postingan.length > 0 ? postingan : [];
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nusa-Media | Portal Berita Multi-Sistem Hybrid</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://w3.org viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📰</text></svg>">
    <script src="https://tailwindcss.com"></script>
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Roboto', sans-serif; }
    </style>
  </head>
  <body class="bg-gray-100 text-gray-900 min-h-screen">

    <script is:inline>0</script>

    <!-- Top Bar Info -->
    <div class="bg-red-700 text-white text-xs py-2">
      <div class="max-w-6xl mx-auto px-4 flex justify-between items-center">
        <div>📍 Regional Pembaruan Nusantara</div>
        <div class="flex items-center gap-4">
          <span class="bg-white/20 px-2 py-0.5 rounded text-[10px] uppercase font-bold tracking-wide">Sumber: {sumberData}</span>
          <div class="flex items-center gap-1.5">
            <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
            <span>Total Berita: {allBerita => semuaBeritaTersedia.length}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Header Branding -->
    <header class="bg-slate-900 text-white border-b-4 border-red-600 shadow-md">
      <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <div>
          <h1 class="text-4xl font-black tracking-tight text-white flex items-center gap-1">
            NUSA<span class="text-red-500">MEDIA</span><span class="text-xs text-gray-400 font-normal border-l border-gray-600 pl-2">ONLINE</span>
          </h1>
          <p class="text-xs text-gray-400 mt-0.5">Media Informasi Hybrid • Supabase & GitHub Sync</p>
        </div>
        <div class="w-full md:w-96 bg-red-50 border border-red-200 text-red-700 font-bold p-3 text-center text-xs rounded shadow-sm">
          Space Iklan Ucapan Selamat & Sukses Instansi / Perorangan
        </div>
      </div>
    </header>

    <!-- Navigasi -->
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
      <div class="max-w-6xl mx-auto px-4 flex items-center gap-6 overflow-x-auto text-sm font-bold h-12">
        <a href="/" class="text-red-600 border-b-2 border-red-600 py-3 px-1 whitespace-nowrap">Home</a>
        <a href="#" class="text-gray-600 hover:text-red-600 py-3 px-1 whitespace-nowrap transition">Semua Berita</a>
      </div>
    </nav>

    <!-- Konten Utama Dua Kolom -->
    <main class="max-w-6xl mx-auto px-4 py-6">
      
      {errorSistem && (
        <div class="bg-red-100 border-l-4 border-red-600 p-4 rounded text-red-800 text-sm mb-6">
          <strong>Kritis:</strong> {errorSistem}
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- KOLOM KIRI & TENGAH -->
        <div class="lg:col-span-2 space-y-6">
          
          <!-- Iklan Atas Dinamis -->
          <div class="w-full">
            {iklanTengah ? (
              <a href={iklanTengah.link_tujuan} target="_blank" class="block w-full bg-emerald-50 border border-emerald-200 rounded p-4 flex flex-col sm:flex-row items-center justify-between gap-4 cursor-pointer hover:bg-emerald-100 transition">
                <div>
                  <span class="bg-emerald-600 text-white text-[10px] font-bold px-2.5 py-0.5 rounded uppercase">Iklan Sponsor Aktif</span>
                  <h4 class="font-bold text-sm text-emerald-900 mt-1">{iklanTengah.konten_teks}</h4>
                </div>
                <span class="text-xs bg-emerald-600 text-white font-bold px-3 py-1.5 rounded whitespace-nowrap">Kunjungi Situs ↗</span>
              </a>
            ) : (
              <div class="w-full bg-slate-50 border border-dashed border-gray-300 p-3 text-center text-gray-400 text-xs rounded">
                Space Ad Center Nusa-Media Tersedia
              </div>
            )}
          </div>

          <!-- Aliran List Semua Berita Grid Layout -->
          <div class="space-y-4">
            <div class="border-b-2 border-slate-800 pb-1">
              <h2 class="bg-slate-800 text-white px-3 py-1 text-xs font-bold uppercase tracking-wider inline-block">Arsip Berita Nusantara</h2>
            </div>
            
            {semuaBeritaTersedia.length > 0 ? (
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                {semuaBeritaTersedia.map((berita) => (
                  <article class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden flex flex-col justify-between hover:shadow-md transition group">
                    <div>
                      <div class="h-44 bg-slate-200 overflow-hidden relative">
                        <img src={berita.image_url || berita.url_gambar || "https://unsplash.com"} alt={berita.judul} class="w-full h-full object-cover group-hover:scale-105 transition duration-300" />
                        <span class="absolute top-3 left-3 bg-red-600 text-white text-[9px] font-black uppercase px-2 py-0.5 rounded shadow-xs tracking-wide">
                          {berita.kategori || 'Fokus'}
                        </span>
                      </div>
                      <div class="p-4">
                        <h3 class="font-bold text-gray-900 group-hover:text-red-600 transition text-base leading-snug line-clamp-2">
                          <a href={`/${berita.slug || berita.id}`}>{berita.judul}</a>
                        </h3>
                        <p class="text-gray-500 text-xs mt-2 line-clamp-3 leading-relaxed">{berita.konten}</p>
                      </div>
                    </div>
                    <div class="text-[10px] text-gray-400 p-4 border-t border-gray-100 flex justify-between items-center bg-gray-50/50">
                      <span>By: {berita.penulis || 'Redaksi'}</span>
                      <span>⏱️ {berita.created_at ? new Date(berita.created_at).toLocaleDateString('id-ID') : 'Baru'}</span>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <div class="bg-white border border-dashed border-gray-300 p-12 text-center text-gray-400 text-sm rounded-xl">
                Tidak ada artikel berita yang ditemukan dalam sistem.
              </div>
            )}
          </div>

        </div>

        <!-- KOLOM KANAN: Sidebar -->
        <div class="space-y-6">
          <div class="border-b-2 border-slate-800 pb-1">
            <h2 class="bg-slate-800 text-white px-3 py-1 text-xs font-bold uppercase tracking-wider inline-block">Sponsor</h2>
          </div>

          {iklanSidebarAtas ? (
            <div class="bg-white border border-gray-200 rounded shadow-sm p-4 text-center">
              <span class="text-[10px] uppercase font-bold text-gray-400 block mb-2">Advertisement</span>
              <p class="text-sm font-bold text-slate-800">{iklanSidebarAtas.konten_teks}</p>
              <a href={iklanSidebarAtas.link_tujuan} target="_blank" class="mt-3 inline-block w-full bg-red-600 text-white text-xs font-bold py-2 rounded hover:bg-red-700 transition">Info Selengkapnya</a>
            </div>
          ) : (
            <div class="bg-white border border-dashed border-gray-300 p-8 text-center text-gray-400 text-xs rounded">
              Space Iklan Sidebar Atas 300x250
            </div>
          )}
        </div>

      </div>
    </main>

    <footer class="bg-slate-900 text-gray-400 text-xs py-6 mt-12 text-center">
      <p class="font-bold text-white mb-1">NUSA MEDIA ONLINE</p>
      <p>&copy; {new Date().getFullYear()} Hak Cipta Dilindungi.</p>
    </footer>
  </body>
</html>
