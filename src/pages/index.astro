---
// FITUR ASTRO: Mengambil data dari database Supabase Anda
import { supabase } from '../lib/supabase'; // Pastikan file ini sudah dibuat

// Mengambil data dan menangkap error dari Supabase
const { data: artikel, error } = await supabase
  .from('posts')
  .select('judul, ringkasan, slug'); // Mengambil kolom yang dibutuhkan saja agar lebih cepat

// Mencetak error di terminal VS Code jika koneksi gagal
if (error) {
  console.error("Terjadi kesalahan Supabase:", error.message);
}
---

<!-- KOLABORASI HTML & ASTRO: -->
<main class="max-w-4xl mx-auto p-4">
  <h1 class="text-3xl font-bold mb-6">Berita Nusa Media</h1>

  <!-- Menampilkan pesan jika koneksi ke Supabase gagal -->
  {error && (
    <div class="p-4 mb-4 text-red-700 bg-red-100 rounded-lg">
      Gagal memuat berita. Silakan periksa koneksi database Anda.
    </div>
  )}

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {/* PENGAMAN: Menambahkan 'artikel &&' agar map tidak error jika data null */}
    {artikel && artikel.map((item) => (
      <article class="p-4 bg-white shadow rounded-lg border border-gray-100">
        <h2 class="text-xl font-semibold text-blue-600">{item.judul}</h2>
        <p class="text-gray-600 mt-2">{item.ringkasan}</p>
        <a href={`/berita/${item.slug}`} class="text-sm text-amber-500 font-bold block mt-4 hover:underline">
          Baca Selengkapnya →
        </a>
      </article>
    ))}

    {/* KONDISI JIKA DATA KOSONG: Menampilkan pesan jika tabel di Supabase belum ada isinya */}
    {artikel && artikel.length === 0 && (
      <p class="text-gray-500 col-span-2 text-center py-8">Belum ada berita terbaru saat ini.</p>
    )}
  </div>
</main>
