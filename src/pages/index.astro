---
// src/pages/index.astro
export const prerender = false; // Menerapkan SSR agar halaman beranda selalu memuat berita paling baru secara real-time

// 🔥 PERBAIKAN MUTLAK: Hapus baris impor Fragment manual karena sudah otomatis ada di Astro
import { supabase } from '../lib/supabase'; 
import '../styles/global.css';

// 1. Ambil daftar seluruh berita terbaru dari tabel Supabase
const { data: daftarBerita, error } = await supabase
  .from('berita')
  .select('*')
  .order('created_at', { ascending: false });

// 2. Ambil seluruh data iklan aktif dari tabel Supabase
const { data: daftarIklan } = await supabase
  .from('iklan')
  .select('*');

// Jika database bermasalah atau kosong, buat array kosong agar aplikasi tidak crash
const beritaSedia = daftarBerita || [];
const iklanSedia = daftarIklan || [];

// 🔥 PENYARING PENGAMAN: Fungsi pembantu penangkap data iklan zona kustom
const ambilIklanZona = (zona) => {
  if (!iklanSedia || iklanSedia.length === 0) return null;
  return iklanSedia.find(ad => ad && ad.zona_penempatan === zona) || null;
};

// Pemetaan 7 Slot Iklan Strategis
const iklanHeader = ambilIklanZona('header_top');
const iklanInArticle = ambilIklanZona('in_article');
const iklanInArticle2 = ambilIklanZona('in_article_2'); 
const iklanSidebar = ambilIklanZona('sidebar_right');
const iklanSidebarSticky = ambilIklanZona('sidebar_sticky'); 
const iklanFooter = ambilIklanZona('footer_banner'); 
const iklanPopup = ambilIklanZona('popup_float'); 

const judulSEO = "Nusa Media | Portal Berita Terkini";
const deskripsiSEO = "Platform media digital modern yang menyajikan informasi valid, cepat, dan mendalam.";
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{judulSEO}</title>
    <meta name="description" content={deskripsiSEO} />
  </head>
  <body class="bg-gray-100 text-gray-900 min-h-screen antialiased pb-24">
    
    <!-- ── 📦 SLOT 1: HEADER TOP AD ── -->
    {iklanHeader && iklanHeader.url_banner_kreatif && (
      <div class="bg-gray-200 border-b border-gray-300 py-3 hidden sm:block">
        <div class="max-w-5xl mx-auto flex flex-col items-center">
          <span class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-1">SPONSOR AD</span>
          <a href={iklanHeader.url_tujuan || '#'} target="_blank" rel="noopener noreferrer" class="block transition hover:opacity-90">
            <img src={iklanHeader.url_banner_kreatif} alt={iklanHeader.nama_sponsor} class="max-h-[90px] w-auto rounded border border-gray-300 shadow-xs" />
          </a>
        </div>
      </div>
    )}

    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-4 py-4 flex justify-between items-center">
        <h1 class="text-xl font-black tracking-tighter text-red-600 uppercase">
          Nusa Media
        </h1>
        <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">Live Updates</span>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-4 py-8">
      <h2 class="text-2xl font-black text-slate-900 mb-6 uppercase tracking-tight">Berita Terbaru</h2>
      
      {error && (
        <div class="bg-red-50 border border-red-200 text-red-700 p-4 rounded-xl mb-6 text-sm">
          Gagal memuat data dari Supabase: {error.message}
        </div>
      )}

      <!-- GRID LIST UTAMA -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <!-- ── 📦 SLOT 4: SIDEBAR BANNER 1 ── -->
        {iklanSidebar && iklanSidebar.url_banner_kreatif && (
          <div class="bg-white border border-gray-200 rounded-xl p-4 shadow-sm flex flex-col justify-center items-center">
            <span class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-2 block border-b w-full text-center pb-1">PARTNER ADVERTISEMENT</span>
            <a href={iklanSidebar.url_tujuan || '#'} target="_blank" rel="noopener noreferrer" class="block w-full">
              <img src={iklanSidebar.url_banner_kreatif} alt={iklanSidebar.nama_sponsor} class="w-full h-auto rounded border object-cover mx-auto" />
            </a>
          </div>
        )}

        <!-- 🔥 PERBAIKAN TOTAL SINTAKSIS: Menggunakan struktur asli bawaan loop Astro yang super kencang & 100% lolos kompilasi esbuild -->
        {beritaSedia.map((item: any, index: number) => (
          <Fragment>
            <article class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col hover:shadow-md transition">
              <div class="h-48 bg-slate-100 overflow-hidden">
                <img 
                  src={item.gambar_url || "https://unsplash.com"} 
                  alt={item.judul} 
                  class="w-full h-full object-cover hover:scale-105 transition duration-300"
                />
              </div>
              
              <div class="p-5 flex flex-col flex-1">
                <div class="mb-2">
                  <span class="bg-red-100 text-red-700 text-[10px] font-extrabold uppercase px-2 py-0.5 rounded">
                    {item.kategori || 'Fokus'}
                  </span>
                </div>
                
                <h3 class="text-lg font-bold text-gray-900 leading-snug mb-2 line-clamp-2">
                  {item.judul}
                </h3>
                
                <p class="text-sm text-gray-500 mb-4 line-clamp-3 flex-1">
                  {(item.ringkasan || item.isi_konten || '').replace(/<[^>]*>/g, '')}
                </p>
                
                <a 
                  href={`/berita/${item.slug || item.id}`} 
                  class="text-sm font-black text-red-600 hover:text-red-700 mt-auto inline-flex items-center gap-1"
                >
                  Baca Selengkapnya →
                </a>
              </div>
            </article>

            <!-- ── 📦 SLOT 2: IN-ARTICLE SELA BERITA 1 ── -->
            {index === 1 && iklanInArticle && iklanInArticle.url_banner_kreatif && (
              <div class="col-span-1 md:col-span-2 lg:col-span-3 bg-white border-2 border-dashed border-gray-200 rounded-xl p-4 flex flex-col items-center justify-center">
                <span class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">SPONSORED CONTENT</span>
                <a href={iklanInArticle.url_tujuan || '#'} target="_blank" rel="noopener noreferrer" class="w-full text-center">
                  <img src={iklanInArticle.url_banner_kreatif} alt={iklanInArticle.nama_sponsor} class="mx-auto rounded border border-gray-100 max-h-[120px] object-contain" />
                </a>
              </div>
            )}

            <!-- ── 📦 SLOT 3: IN-ARTICLE SELA BERITA 2 ── -->
            {index === 3 && iklanInArticle2 && iklanInArticle2.url_banner_kreatif && (
              <div class="col-span-1 md:col-span-2 lg:col-span-3 bg-white border-2 border-dashed border-gray-200 rounded-xl p-4 flex flex-col items-center justify-center">
                <span class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-1.5">RECOMMENDED SPONSOR</span>
                <a href={iklanInArticle2.url_tujuan || '#'} target="_blank" rel="noopener noreferrer" class="w-full text-center">
                  <img src={iklanInArticle2.url_banner_kreatif} alt={iklanInArticle2.nama_sponsor} class="mx-auto rounded border border-gray-100 max-h-[120px] object-contain" />
                </a>
              </div>
            )}
          </Fragment>
        ))}

        <!-- ── 📦 SLOT 5: SIDEBAR BANNER 2 STICKY ── -->
        {iklanSidebarSticky && iklanSidebarSticky.url_banner_kreatif && (
          <div class="bg-white border border-gray-200 rounded-xl p-4 shadow-sm flex flex-col justify-center items-center">
            <h3 class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-2 border-b w-full text-center pb-1">PREMIUM SPONSOR</h3>
            <a href={iklanSidebarSticky.url_tujuan || '#'} target="_blank" rel="noopener noreferrer" class="block w-full">
              <img src={iklanSidebarSticky.url_banner_kreatif} alt={iklanSidebarSticky.nama_sponsor} class="w-full h-auto rounded border object-cover mx-auto" />
            </a>
          </div>
        )}

      </div>
    </main>

    <!-- ── 📦 SLOT 6: FOOTER WIDE BANNER ── -->
    {iklanFooter && iklanFooter.url_banner_kreatif && (
      <footer class="mt-12 bg-white border-t border-gray-200 py-6">
        <div class="max-w-5xl mx-auto px-4 flex flex-col items-center">
          <span class="text-[8px] font-bold text-gray-400 tracking-widest mb-2">COMMERCIAL BANNER</span>
          <a href={iklanFooter.url_tujuan || '#'} target="_blank" rel="noopener noreferrer" class="w-full max-w-3xl block transition hover:opacity-95">
            <img src={iklanFooter.url_banner_kreatif} alt={iklanFooter.nama_sponsor} class="w-full h-auto rounded border border-gray-200" />
          </a>
        </div>
      </footer>
    )}

    <!-- ── 📦 SLOT 7: POPUP FLOAT AD ── -->
    {iklanPopup && iklanPopup.url_banner_kreatif && (
      <div class="fixed bottom-4 right-4 z-50 max-w-[260px] bg-white border border-gray-300 p-2 rounded-xl shadow-2xl hidden sm:block">
        <div class="flex justify-between items-center mb-1 px-1">
          <span class="text-[8px] font-black text-red-500 uppercase tracking-widest">Sponsored</span>
          <button onclick="this.parentElement.parentElement.remove()" class="text-xs font-bold text-gray-400 hover:text-black cursor-pointer px-1">✕</button>
        </div>
        <a href={iklanPopup.url_tujuan || '#'} target="_blank" rel="noopener noreferrer" class="block">
          <img src={iklanPopup.url_banner_kreatif} alt={iklanPopup.nama_sponsor} class="w-full h-auto rounded" />
        </a>
      </div>
    )}

  </body>
</html>
