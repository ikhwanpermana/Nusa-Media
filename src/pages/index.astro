---
const judulHalaman = "Nusa Media - Informasi Akurat, Menjangkau Nusantara";
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{judulHalaman}</title>
    <script src="https://tailwindcss.com"></script>
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Plus Jakarta Sans', sans-serif; }
      .brand-title { font-family: 'Playfair Display', Georgia, serif; }
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
  </head>
  <body class="bg-[#FBFBFA] text-[#1A1A1A] antialiased min-h-screen flex flex-col justify-between">

    <header class="bg-white border-b border-gray-200 pt-6">
      <div class="max-w-6xl mx-auto px-6 text-center space-y-2">
        <p class="text-[10px] font-bold tracking-widest text-gray-400 uppercase font-mono">Rabu, 20 Mei 2026</p>
        <h1 class="brand-title text-4xl md:text-5xl font-black tracking-tight text-gray-900 select-none cursor-pointer">
          NUSA <span class="italic text-blue-600">MEDIA</span>
        </h1>
        <p class="text-xs italic text-gray-500 font-serif max-w-md mx-auto pb-4 border-b border-gray-100">
          "Informasi Akurat, Menjangkau Nusantara"
        </p>
      </div>

      <div class="bg-white sticky top-0 z-50 border-b border-gray-200 shadow-sm">
        <div class="max-w-6xl mx-auto px-4">
          <div class="flex items-center justify-between">
            <nav id="menuKategori" class="flex items-center gap-1 overflow-x-auto no-scrollbar py-3 text-xs md:text-sm font-bold tracking-wide text-gray-600 w-full md:w-auto">
              <button onclick="filterKategori('SEMUA', this)" class="px-3.5 py-1.5 rounded-full bg-blue-600 text-white cursor-pointer shrink-0">SEMUA BERITA</button>
              <button onclick="filterKategori('TEKNOLOGI', this)" class="px-3.5 py-1.5 rounded-full hover:bg-gray-100 text-gray-600 cursor-pointer shrink-0">TEKNOLOGI</button>
              <button onclick="filterKategori('POLITIK', this)" class="px-3.5 py-1.5 rounded-full hover:bg-gray-100 text-gray-600 cursor-pointer shrink-0">POLITIK</button>
              <button onclick="filterKategori('BISNIS', this)" class="px-3.5 py-1.5 rounded-full hover:bg-gray-100 text-gray-600 cursor-pointer shrink-0">BISNIS</button>
              <button onclick="filterKategori('GAYA HIDUP', this)" class="px-3.5 py-1.5 rounded-full hover:bg-gray-100 text-gray-600 cursor-pointer shrink-0">GAYA HIDUP</button>
            </nav>
            <a href="/admin" class="hidden md:inline-block text-[11px] font-mono font-bold text-gray-400 hover:text-blue-600 border border-gray-200 px-2.5 py-1 rounded-md bg-gray-50 shadow-sm">Portal Admin ↗</a>
          </div>
        </div>
      </div>
    </header>

    <main class="max-w-6xl w-full mx-auto p-6 flex-grow space-y-12">
      <section id="headlineBerita" class="hidden"></section>
      <section class="space-y-6">
        <h3 id="labelGrid" class="text-xs font-black tracking-wider text-gray-400 uppercase font-mono border-b border-gray-200 pb-2">Berita Terbaru</h3>
        <div id="gridBerita" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- 🎯 PERBAIKAN: Mengunci array 3 baris agar tidak memicu error Astro build -->
          {[1, 2, 3].map(() => (
            <div class="bg-white rounded-xl border border-gray-100 overflow-hidden shadow-sm animate-pulse">
              <div class="aspect-video bg-gray-200 w-full"></div>
              <div class="p-5 space-y-3">
                <div class="h-3 bg-gray-200 rounded w-1/3"></div>
                <div class="h-5 bg-gray-200 rounded w-full"></div>
              </div>
            </div>
          ))}
        </div>
      </section>
    </main>

    <footer class="bg-[#111111] text-gray-500 border-t border-zinc-800 py-10 px-6 text-center text-xs mt-20">
      <p>&copy; 2026 Nusa Media. Hak Cipta Dilindungi Undang-Undang.</p>
    </footer>

    <script is:inline>
      const headlineContainer = document.getElementById('headlineBerita');
      const gridContainer = document.getElementById('gridBerita');
      const labelGrid = document.getElementById('labelGrid');
      let semuaDataBerita = []; 

      const SUPABASE_PROJECT_ID = "zmvlvzspjohrewjbtfxc"; 
      const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inptdmx2enNwam9ocmV3amJ0ZnhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMTM0MTAsImV4cCI6MjA5NDU4OTQxMH0.PtTVq_b4gLonRpNSbPYKncoXlGVS1lKaADy74dbhuSI";     
      const API_URL = `https://${SUPABASE_PROJECT_ID}.supabase.co/rest/v1/berita?select=*&order=dibuat_pada.desc`;
      
      async function ambilBeritaPublik() {
        try {
          const response = await fetch(API_URL, {
            headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
          });
          semuaDataBerita = await response.json();
          distribusiDanRender(semuaDataBerita, true);
        } catch (error) {
          gridContainer.innerHTML = `<div class="col-span-full text-center text-red-500">🛑 Gagal terhubung ke database</div>`;
        }
      }

      function distribusiDanRender(data, tampilkanHeadlineUtama) {
        if (!data || data.length === 0) {
          headlineContainer.classList.add('hidden');
          gridContainer.innerHTML = `<div class="col-span-full text-center py-10 text-gray-400">Tidak ada berita ditemukan.</div>`;
          return;
        }
        if (tampilkanHeadlineUtama && data.length > 0) {
          renderHeadline(data[0]);
          renderGrid(data.slice(1));
          labelGrid.innerText = "Berita Terbaru Lainnya";
        } else {
          headlineContainer.classList.add('hidden');
          renderGrid(data);
          labelGrid.innerText = "Hasil Pencarian Kategori";
        }
      }

      function renderHeadline(item) {
        headlineContainer.classList.remove('hidden');
        headlineContainer.innerHTML = `
          <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-xs p-6 grid grid-cols-1 lg:grid-cols-5 gap-6">
            <div class="lg:col-span-3"><img src="${item.url_gambar || 'https://unsplash.com'}" class="w-full h-64 object-cover rounded-xl"/></div>
            <div class="lg:col-span-2 flex flex-col justify-center space-y-3">
              <span class="text-[10px] font-bold text-blue-600 uppercase font-mono">${item.kategori || 'UMUM'}</span>
              <h2 class="brand-title text-2xl font-black text-gray-900">${item.judul || 'Tanpa Judul'}</h2>
              <p class="text-gray-500 text-xs line-clamp-3">${item.konten || ''}</p>
              <p class="text-[10px] text-gray-400 font-mono">${item.penulis || 'Redaksi'} • ${item.dibuat_pada ? new Date(item.dibuat_pada).toLocaleDateString('id-ID') : ''}</p>
            </div>
          </div>`;
      }

      function renderGrid(data) {
        gridContainer.innerHTML = data.map(item => `
          <div class="bg-white rounded-xl border border-gray-200 shadow-xs overflow-hidden p-5 space-y-3">
            <img src="${item.url_gambar || 'https://unsplash.com'}" class="w-full h-40 object-cover rounded-lg"/>
            <span class="text-[9px] font-bold text-gray-400 uppercase font-mono">${item.kategori || 'UMUM'}</span>
            <h3 class="font-bold text-gray-900 text-base line-clamp-2">${item.judul || 'Tanpa Judul'}</h3>
            <p class="text-gray-500 text-xs line-clamp-2">${item.konten || ''}</p>
          </div>
        `).join('');
      }

      function filterKategori(kategori, elemenTombol) {
        document.querySelectorAll('#menuKategori button').forEach(btn => btn.classList.remove('bg-blue-600', 'text-white'));
        elemenTombol.classList.add('bg-blue-600', 'text-white');
        if (kategori === 'SEMUA') {
          distribusiDanRender(semuaDataBerita, true);
        } else {
          distribusiDanRender(semuaDataBerita.filter(item => item.kategori?.toUpperCase() === kategori.toUpperCase(), false));
        }
      }
      ambilBeritaPublik();
    </script>
  </body>
</html>
