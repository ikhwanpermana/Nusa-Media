---
import { supabase } from '../../lib/supabase';

export const prerender = false;

const { id } = Astro.params;

// Ambil data detail satu berita berdasarkan ID
const { data: berita, error } = await supabase
  .from('berita')
  .select('*')
  .eq('id', id)
  .maybeSingle();

if (error || !berita) {
  return Astro.redirect('/404');
}
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{berita.judul} | Nusa-Media</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://w3.org viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📰</text></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Roboto', sans-serif; }</style>
  </head>
  <body class="bg-gray-100 text-gray-900 min-h-screen">
    
    <main class="max-w-3xl mx-auto px-4 py-8">
      <a href="/" class="text-sm font-bold text-red-600 hover:underline inline-block mb-6">← Kembali ke Beranda</a>
      
      <article class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden p-6 md:p-8">
        <div class="mb-4">
          <span class="bg-red-600 text-white text-[10px] font-black uppercase px-2.5 py-1 rounded">
            {berita.kategori || 'Fokus'}
          </span>
          <span class="text-xs text-gray-400 ml-3">
            {berita.created_at ? new Date(berita.created_at).toLocaleDateString('id-ID', { dateStyle: 'long' }) : ''}
          </span>
        </div>

        <h1 class="text-2xl md:text-4xl font-black text-slate-900 leading-tight mb-4">
          {berita.judul}
        </h1>

        <div class="text-xs text-gray-500 border-b pb-4 mb-6">
          Penulis: <span class="font-bold text-gray-700">{berita.penulis || berita.sumber || 'Redaksi Nusa Media'}</span>
        </div>

        {/* Gambar Utama Detail */}
        <div class="w-full h-64 md:h-[400px] bg-slate-100 rounded-lg overflow-hidden mb-6 shadow-inner">
          <img 
            src={berita.gambar_url || berita.image_url || "https://unsplash.com"} 
            alt={berita.judul} 
            class="w-full h-full object-cover"
          />
        </div>

        {/* Isi Konten Lengkap */}
        <div class="text-gray-800 text-base md:text-lg leading-relaxed whitespace-pre-line">
          {berita.isi_konten || berita.konten || berita.ringkasan}
        </div>
      </article>
    </main>
    
  </body>
</html>
