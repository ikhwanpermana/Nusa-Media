---
import { supabase } from '../lib/supabase';

// Menangkap kunci rahasia admin dari URL (Sesuai nama file [id].astro)
const { id: adminKey } = Astro.params;

// Tentukan Kunci Rahasia Anda di sini agar tidak sembarang orang bisa input data
const KUNCI_AKSES_ADMIN = "admin-rahasia-99"; 

let statusPesan = "";
let tipePesan = ""; // "sukses" atau "gagal"

// Eksekusi jika admin menekan tombol Simpan (Metode POST)
if (Astro.request.method === "POST") {
  try {
    const dataForm = await Astro.request.formData();
    const tipeInput = dataForm.get("tipe_input"); // "berita" atau "iklan"

    if (tipeInput === "berita") {
      // 📰 LOGIKA INPUT BERITA
      const judul = dataForm.get("judul");
      const kategori = dataForm.get("kategori");
      const konten = dataForm.get("konten");

      // ✨ Catatan Keamanan: Pastikan nama tabel di Supabase Anda adalah 'artikel'
      const { error } = await supabase
        .from('artikel')
        .insert([{ judul, kategori, konten }]);

      if (error) throw error;
      statusPesan = "Berita baru berhasil diterbitkan secara live!";
      tipePesan = "sukses";

    } else if (tipeInput === "iklan") {
      // 📢 LOGIKA INPUT IKLAN
      const kontenTeks = dataForm.get("konten_teks");
      const linkTujuan = dataForm.get("link_tujuan");
      const posisi = dataForm.get("posisi"); // "detail_atas", "sidebar_atas"

      const { error } = await supabase
        .from('iklan')
        .insert([{ konten_teks: kontenTeks, link_tujuan: linkTujuan, posisi, status: 'aktif' }]);

      if (error) throw error;
      statusPesan = "Iklan komersial baru berhasil dipasang!";
      tipePesan = "sukses";
    }
  } catch (err) {
    // 🛠️ PERBAIKAN 1: Menghapus ': any' agar tidak memicu strict type error saat rilis di Netlify
    const pesanError = err instanceof Error ? err.message : "Terjadi kesalahan sistem";
    statusPesan = `Gagal menyimpan data: ${pesanError}`;
    tipePesan = "gagal";
  }
}
---

<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sistem Input Nusa-Media</title>
  <link rel="preconnect" href="https://googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet">
  <script src="https://tailwindcss.com"></script>
  <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen p-4 sm:p-8">

  <!-- Validasi Keamanan Kunci URL -->
  {adminKey !== KUNCI_AKSES_ADMIN ? (
    <div class="max-w-md mx-auto text-center bg-slate-800 border border-red-500/30 p-8 rounded-2xl shadow-xl mt-12">
      <span class="text-4xl">🚫</span>
      <h2 class="text-xl font-bold text-red-400 mt-4">Akses Ditolak</h2>
      <p class="text-slate-400 text-sm mt-2">Kunci ID URL admin yang Anda masukkan tidak cocok atau salah.</p>
      <a href="/" class="inline-block mt-6 text-xs bg-slate-700 px-4 py-2 rounded-xl text-white">Kembali ke Home</a>
    </div>
  ) : (
    
    // TAMPILAN DASHBOARD INPUT UTAMA
    <div class="max-w-2xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-2xl font-bold tracking-tight">Nusa-Media Control Center</h1>
          <p class="text-xs text-slate-400 mt-1">Mode penginputan manual berita dan slot iklan sponsor daerah</p>
        </div>
        <a href="/" class="text-xs bg-slate-800 text-slate-300 px-3 py-1.5 rounded-lg border border-slate-700">Lihat Web Live ↗</a>
      </div>

      <!-- Notifikasi Status Pengiriman Data -->
      {statusPesan && (
        <div class={`p-4 rounded-xl text-sm font-semibold mb-6 border ${
          tipePesan === "sukses" ? "bg-emerald-950/50 border-emerald-500/30 text-emerald-400" : "bg-rose-950/50 border-rose-500/30 text-rose-400"
        }`}>
          {tipePesan === "sukses" ? "✅" : "⚠️"} {statusPesan}
        </div>
      )}

      <!-- KARTU FORMULIR -->
      <div class="bg-slate-800 border border-slate-700/60 rounded-2xl p-6 shadow-xl">
        
        <!-- Pemilih Tab Input -->
        <div class="flex bg-slate-900 p-1.5 rounded-xl gap-2 mb-6 text-sm font-bold">
          <button id="btn-berita" class="w-full py-2 bg-indigo-600 text-white rounded-lg transition" onclick="switchTab('berita')">
            📰 Tulis Berita Baru
          </button>
          <button id="btn-iklan" class="w-full py-2 text-slate-400 hover:text-white rounded-lg transition" onclick="switchTab('iklan')">
            📢 Pasang Iklan Baru
          </button>
        </div>

        <!-- FORMULIR INPUT BERITA -->
        <form id="form-berita" method="POST" class="space-y-4">
          <input type="hidden" name="tipe_input" value="berita" />
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400">Judul Berita</label>
            <input type="text" name="judul" required class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 text-sm mt-1.5 focus:border-indigo-500 focus:outline-none text-slate-100" placeholder="Masukkan judul berita terhangat..." />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400">Kategori Wilayah / Rubrik</label>
            <select name="kategori" class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 text-sm mt-1.5 focus:border-indigo-500 focus:outline-none text-slate-300">
              <option value="Fokus">Fokus Utama</option>
              <option value="Politik">Politik</option>
              <option value="Advertorial">Advertorial Daerah</option>
              <option value="Ekonomi">Ekonomi</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400">Isi Konten Berita</label>
            <textarea name="konten" rows="8" required class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 text-sm mt-1.5 focus:border-indigo-500 focus:outline-none text-slate-100" placeholder="Ketik isi berita lengkap di sini..."></textarea>
          </div>
          <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 px-4 rounded-xl shadow-lg shadow-indigo-600/20 transition-all text-sm mt-2">
            Terbitkan Berita Sekarang
          </button>
        </form>

        <!-- FORMULIR INPUT IKLAN (Sembunyi default) -->
        <form id="form-iklan" method="POST" class="space-y-4 hidden">
          <input type="hidden" name="tipe_input" value="iklan" />
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400">Teks / Nama Iklan</label>
            <input type="text" name="konten_teks" required class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 text-sm mt-1.5 focus:border-indigo-500 focus:outline-none text-slate-100" placeholder="Contoh: Ucapan Selamat Hari Jadi Kabupaten..." />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400">Link Tujuan Iklan (URL Sponsor)</label>
            <input type="url" name="link_tujuan" required class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 text-sm mt-1.5 focus:border-indigo-500 focus:outline-none text-slate-100" placeholder="https://instansidaerah.go.id" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-400">Posisi Slot Penempatan Iklan</label>
            <select name="posisi" class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 text-sm mt-1.5 focus:border-indigo-500 focus:outline-none text-slate-300">
              <option value="detail_atas">Bagian Atas Konten Berita</option>
              <option value="sidebar_atas">Sidebar Samping Kanan Atas</option>
              <option value="sidebar_bawah">Sidebar Samping Kanan Bawah</option>
            </select>
          </div>
          <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold py-3 px-4 rounded-xl shadow-lg shadow-emerald-600/20 transition-all text-sm mt-2">
            Pasang Iklan Sponsor
          </button>
        </form>

      </div>
    </div>
  )}

  <!-- 🛠️ PERBAIKAN 2: Script Client Lengkap untuk Operasional Alih Tab Form -->
  <script is:inline>
    function switchTab(type) {
      const formBerita = document.getElementById('form-berita');
      const formIklan = document.getElementById('form-iklan');
      const btnBerita = document.getElementById('btn-berita');
      const btnIklan = document.getElementById('btn-iklan');
      
      if (type === 'berita') {
        formBerita.classList.remove('hidden');
        formIklan.classList.add('hidden');
        btnBerita.className = "w-full py-2 bg-indigo-600 text-white rounded-lg transition";
        btnIklan.className = "w-full py-2 text-slate-400 hover:text-white rounded-lg transition";
      } else {
        formBerita.classList.add('hidden');
        formIklan.classList.remove('hidden');
        btnBerita.className = "w-full py-2 text-slate-400 hover:text-white rounded-lg transition";
        btnIklan.className = "w-full py-2 bg-emerald-600 text-white rounded-lg transition";
      }
    }
  </script>
</body>
</html>
