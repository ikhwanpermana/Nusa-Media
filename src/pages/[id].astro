---
// 1. Impor koneksi database Supabase resmi
import { supabase } from '../lib/supabase';

// 2. WAJIB DI MODE STATIS (SSG): Beri tahu Astro daftar ID berita apa saja yang ada di Supabase
export async function getStaticPaths() {
  const SUPABASE_PROJECT_ID = "zmvlvzspjohrewjbtfxc";
  const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inptdmx2enNwam9ocmV3amJ0ZnhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMTM0MTAsImV4cCI6MjA5NDU4OTQxMH0.PtTVq_b4gLonRpNSbPYKncoXlGVS1lKaADy74dbhuSI";
  
  try {
    // Ambil semua ID dari tabel berita
    const response = await fetch(`https://${SUPABASE_PROJECT_ID}.supabase.co/rest/v1/berita?select=id`, {
      headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
    });
    const daftarBerita = await response.json();
    
    // Kembalikan rute parameter ID ke mesin build Astro
    return daftarBerita.map((berita) => ({
      params: { id: berita.id.toString() },
    }));
  } catch (error) {
    console.error("Gagal membuat rute statis:", error);
    return [];
  }
}

// 3. Ambil parameter ID dari URL halaman aktif
const { id } = Astro.params;

// 4. Ambil data berita lengkap sesuai ID yang sedang dibuka (Fetch Sisi Server saat Build)
const SUPABASE_PROJECT_ID = "zmvlvzspjohrewjbtfxc";
const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inptdmx2enNwam9ocmV3amJ0ZnhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMTM0MTAsImV4cCI6MjA5NDU4OTQxMH0.PtTVq_b4gLonRpNSbPYKncoXlGVS1lKaADy74dbhuSI";

const response = await fetch(`https://${SUPABASE_PROJECT_ID}.supabase.co/rest/v1/berita?id=eq.${id}&select=*`, {
  headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
});
const dataBerita = await response.json();
const berita = dataBerita[0];
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{berita ? berita.judul : 'Detail Berita'} - Nusa Media</title>
    <script src="https://tailwindcss.com"></script>
  </head>
  <body class="bg-[#FBFBFA] text-[#1A1A1A] antialiased">
    
    <!-- Tombol Kembali -->
    <div class="max-w-3xl mx-auto px-6 pt-10">
      <a href="/" class="text-xs font-bold text-blue-600 hover:text-blue-700 tracking-wide uppercase font-mono">
        ← Kembali ke Beranda
      </a>
    </div>

    <!-- Konten Detail Artikel Koran Premium -->
    {berita ? (
      <main class="max-w-3xl mx-auto px-6 py-8 space-y-6">
        <span class="bg-zinc-900 text-white text-[9px] font-extrabold px-2.5 py-1 rounded-sm uppercase tracking-widest">
          {berita.kategori}
        </span>
        
        <h1 class="text-3xl md:text-4xl font-black text-gray-900 leading-tight tracking-tight font-serif">
          {berita.judul}
        </h1>

        <div class="flex items-center gap-2 text-xs text-gray-400 font-mono border-b border-gray-100 pb-4">
          <span class="font-bold text-gray-700">{berita.penulis || 'Redaksi'}</span>
          <span>•</span>
          <span>{new Date(berita.dibuat_pada).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
        </div>

        <div class="aspect-video w-full bg-gray-100 rounded-xl overflow-hidden shadow-xs">
          <img src={berita.url_gambar} alt={berita.judul} class="w-full h-full object-cover" />
        </div>

        <p class="text-gray-800 text-base md:text-lg leading-relaxed text-justify whitespace-pre-line font-serif pt-4">
          {berita.konten}
        </p>
      </main>
    ) : (
      <div class="text-center py-20 text-gray-400">Berita tidak ditemukan atau telah dihapus.</div>
    )}

  </body>
</html>
