---
// src/pages/kontak.astro
const NOMOR_WHATSAPP = "6281234567890"; // ⚠️ GANTI dengan nomor WhatsApp Anda (awali dengan 6285343632718)
const PESAN_DEFAULT_REDAKSI = encodeURIComponent("Halo Redaksi Nusa Media, saya ingin mengirimkan info/siaran pers.");
const PESAN_DEFAULT_IKLAN = encodeURIComponent("Halo Bagian Iklan Nusa Media, saya tertarik untuk memasang space iklan sponsor.");
---

<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hubungi Kami - Nusa Media</title>
  <link rel="preconnect" href="https://googleapis.com">
  <link href="https://googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
  <style>body { font-family: 'Roboto', sans-serif; }</style>
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col justify-between">

  <main class="max-w-3xl mx-auto px-4 py-12 w-full">
    <a href="/" class="text-xs font-bold text-red-600 uppercase tracking-wider hover:underline">&larr; Kembali ke Beranda</a>
    
    <h1 class="text-4xl font-black tracking-tight text-slate-900 mt-4 border-b-4 border-slate-900 pb-2">HUBUNGI KAMI</h1>
    <p class="text-sm text-gray-500 mt-2">Layanan interaksi pembaca, redaksi, dan kerja sama periklanan komersial regional.</p>

    <!-- KARTU HUBUNGI JALUR CEPAT -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
      
      <!-- Opsi 1: Redaksi -->
      <div class="bg-white border border-gray-200 p-6 rounded-xl shadow-sm flex flex-col justify-between">
        <div>
          <span class="text-[10px] font-bold bg-slate-900 text-white px-2.5 py-1 rounded uppercase tracking-wide">Redaksi & Jurnalisme</span>
          <h3 class="text-lg font-bold mt-3 text-slate-900">Kirim Berita / Siaran Pers</h3>
          <p class="text-xs text-gray-500 mt-1 leading-relaxed">Punya informasi viral atau kejadian penting di sekitar Anda? Hubungi meja redaksi kami untuk diterbitkan.</p>
        </div>
        <a href={`https://wa.me{NOMOR_WHATSAPP}?text=${PESAN_DEFAULT_REDAKSI}`} target="_blank" class="block text-center bg-slate-900 hover:bg-red-600 text-white font-bold text-xs py-3 px-4 rounded-lg mt-6 transition-colors">
          Hubungi Redaksi via WA &rarr;
        </a>
      </div>

      <!-- Opsi 2: Pemasangan Iklan -->
      <div class="bg-white border border-gray-200 p-6 rounded-xl shadow-sm flex flex-col justify-between border-l-4 border-l-red-600">
        <div>
          <span class="text-[10px] font-bold bg-red-600 text-white px-2.5 py-1 rounded uppercase tracking-wide">Marketing & Iklan</span>
          <h3 class="text-lg font-bold mt-3 text-slate-900">Kerja Sama Slot Sponsor</h3>
          <p class="text-xs text-gray-500 mt-1 leading-relaxed">Ubah slot iklan kosong di website Nusa Media menjadi mesin promosi bisnis, ucapan selamat instansi, atau acara Anda.</p>
        </div>
        <a href={`https://wa.me{NOMOR_WHATSAPP}?text=${PESAN_DEFAULT_IKLAN}`} target="_blank" class="block text-center bg-red-600 hover:bg-slate-900 text-white font-bold text-xs py-3 px-4 rounded-lg mt-6 transition-colors">
          Pasang Iklan via WA &rarr;
        </a>
      </div>

    </div>

    <!-- PANDUAN FORMAL UNTUK ADSENSE -->
    <div class="bg-slate-100 p-4 rounded-xl mt-8 text-xs text-gray-600 leading-relaxed border border-gray-200">
      <strong>Informasi Tambahan:</strong> Korespondensi resmi melalui surat elektronik (Email) dapat dilayangkan melalui alamat <span class="font-mono text-slate-900">redaksi@nusa-media.com</span>. Kami berkomitmen merespons setiap masukan dalam waktu maksimal 2x24 jam kerja.
    </div>
  </main>

  <footer class="bg-slate-900 text-gray-500 text-[11px] py-4 text-center border-t border-gray-800">
    &copy; 2026 NUSA MEDIA NETWORK. All Rights Reserved.
  </footer>
</body>
</html>
