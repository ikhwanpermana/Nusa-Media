---
// src/pages/admin-rahasia-99/index.astro
export const prerender = false; // DINAMIS: Menggunakan server-side rendering agar tidak 404 di Vercel akibat Supabase
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nusa-Media Control Center</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://w3.org viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📰</text></svg>">
    <script src="https://tailwindcss.com"></script>
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Roboto', sans-serif; }</style>
  </head>
  <body class="bg-gray-100 p-4 md:p-8 text-gray-900 min-h-screen">

    <div class="max-w-4xl mx-auto space-y-8">
      
      <!-- HEADER PANEL -->
      <div class="bg-slate-900 text-white p-6 rounded-2xl shadow-sm border-b-4 border-red-600 flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-black tracking-tight"># Nusa-Media Control Center</h1>
          <p class="text-xs text-gray-400 mt-1 uppercase tracking-wider">Sistem Input Berita & Manajemen Iklan Dinamis</p>
        </div>
        <a href="/" class="text-xs bg-red-600 hover:bg-red-700 text-white font-bold px-3 py-2 rounded-lg transition">Lihat Beranda ↗</a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- FORM 1: INPUT BERITA BARU -->
        <div class="lg:col-span-2 bg-white p-6 rounded-2xl border border-gray-200 shadow-xs">
          <h2 class="text-lg font-black text-slate-800 mb-4 pb-2 border-b">📰 Tulis Artikel Berita Baru</h2>
          <form id="form-berita" class="space-y-4">
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Judul Utama Berita</label>
              <input type="text" id="judul" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Ketik judul berita terhangat..." required />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">URL Slug (Otomatis Terisi)</label>
              <input type="text" id="slug" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none bg-gray-100 text-gray-500" placeholder="otomatis-terbentuk-dari-judul" readonly required />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Kategori Liputan</label>
                <select id="kategori" class="w-full border rounded-lg px-3 py-2 text-sm bg-gray-50 focus:outline-none focus:border-red-500">
                  <option value="Politik & Ekonomi">Politik & Ekonomi</option>
                  <option value="Teknologi Digital">Teknologi Digital</option>
                  <option value="Nusantara Global">Nusantara Global</option>
                  <option value="Olahraga & Gaya Hidup">Olahraga & Gaya Hidup</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Nama Penulis / Inisial</label>
                <input type="text" id="penulis" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Redaksi" />
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Tautan URL Gambar Pendukung</label>
              <input type="url" id="gambar_url" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="https://unsplash.com..." />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Ringkasan Singkat (Lead)</label>
              <input type="text" id="ringkasan" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Ketik 1 kalimat ringkasan utama..." required />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Isi Konten Berita Lengkap</label>
              <textarea id="isi_konten" rows="8" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Ketik isi berita lengkap di sini..." required></textarea>
            </div>
            <button type="submit" class="w-full bg-slate-900 hover:bg-slate-800 text-white font-bold py-3 rounded-xl text-sm transition shadow-xs">
              Terbitkan Berita Sekarang 🚀
            </button>
          </form>
        </div>

        <!-- FORM 2: INPUT IKLAN SPONSOR -->
        <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-xs h-fit">
          <h2 class="text-lg font-black text-slate-800 mb-4 pb-2 border-b">💎 Pasang Iklan Sponsor</h2>
          <form id="form-iklan" class="space-y-4">
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Teks / URL Foto Banner Iklan</label>
              <input type="text" id="konten_teks" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Ketik kalimat ucapan ATAU tautan URL gambar banner..." required />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Link Tujuan Iklan (URL Klik)</label>
              <input type="url" id="link_tujuan" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="https://perusahaan.com" required />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Posisi Penempatan Banner</label>
              <select id="posisi" class="w-full border rounded-lg px-3 py-2 text-sm bg-gray-50 focus:outline-none focus:border-red-500">
                <option value="detail_atas">Banner Atas (Tengah)</option>
                <option value="sidebar_atas">Kolom Pengumuman (Kanan)</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Status Penayangan</label>
              <select id="status" class="w-full border rounded-lg px-3 py-2 text-sm bg-gray-50 focus:outline-none focus:border-red-500">
                <option value="aktif">Langsung Aktif & Tayang</option>
                <option value="nonaktif">Draft (Sembunyikan)</option>
              </select>
            </div>
            <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 rounded-xl text-sm transition shadow-xs">
              Pasang Iklan Komersial Sekarang 💸
            </button>
          </form>
        </div>

      </div>

    </div>

    <!-- LOGIKA SINKRONISASI BROWSER (CLIENT-SIDE) -->
    <script>
      import { supabase } from '../../lib/supabase';

      // 1. GENERATOR SLUG OTOMATIS
      const inputJudul = document.getElementById('judul') as HTMLInputElement;
      const inputSlug = document.getElementById('slug') as HTMLInputElement;

      inputJudul?.addEventListener('input', () => {
        if (inputSlug) {
          inputSlug.value = inputJudul.value
            .toLowerCase()
            .replace(/[^a-z0-9\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .trim();
        }
      });

      // 2. SUBMIT FORM BERITA KE SUPABASE
      const formBerita = document.getElementById('form-berita') as HTMLFormElement;
      formBerita?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!inputJudul || !inputSlug) return;
        
        const btn = formBerita.querySelector('button[type="submit"]') as HTMLButtonElement;
        const textAwal = btn.innerText;
        btn.disabled = true; 
        btn.innerText = "Mengunggah berita... ⏳";

        const kategori = (document.getElementById('kategori') as HTMLSelectElement).value;
        const penulis = (document.getElementById('penulis') as HTMLInputElement).value;
        const gambar_url = (document.getElementById('gambar_url') as HTMLInputElement).value;
        const ringkasan = (document.getElementById('ringkasan') as HTMLInputElement).value;
        const isi_konten = (document.getElementById('isi_konten') as HTMLTextAreaElement).value;

        const { error } = await supabase
          .from('berita')
          .insert([
            { 
              judul: inputJudul.value, 
              slug: inputSlug.value, 
              kategori, 
              penulis, 
              gambar_url, 
              ringkasan, 
              isi_konten 
            }
          ]);

        if (error) {
          alert('Gagal menerbitkan berita: ' + error.message);
        } else {
          alert('Berita berhasil diterbitkan! 🚀');
          formBerita.reset();
        }

        btn.disabled = false;
        btn.innerText = textAwal;
      });

      // 3. SUBMIT FORM IKLAN KE SUPABASE
      const formIklan = document.getElementById('form-iklan') as HTMLFormElement;
      formIklan?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const btn = formIklan.querySelector('button[type="submit"]') as HTMLButtonElement;
        const textAwal = btn.innerText;
        btn.disabled = true; 
        btn.innerText = "Memasang iklan... ⏳";

        const konten_teks = (document.getElementById('konten_teks') as HTMLInputElement).value;
        const link_tujuan = (document.getElementById('link_tujuan') as HTMLInputElement).value;
        const posisi = (document.getElementById('posisi') as HTMLSelectElement).value;
        const status = (document.getElementById('status') as HTMLSelectElement).value;

        const { error } = await supabase
          .from('iklan')
          .insert([
            { 
              konten_teks, 
              link_tujuan, 
              posisi, 
              status 
            }
          ]);

        if (error) {
          alert('Gagal memasang iklan: ' + error.message);
        } else {
          alert('Iklan berhasil terpasang! 💸');
          formIklan.reset();
        }

        btn.disabled = false;
        btn.innerText = textAwal;
      });
    </script>
  </body>
</html>
