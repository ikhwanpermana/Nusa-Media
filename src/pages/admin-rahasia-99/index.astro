---
// src/pages/admin-rahasia-99/index.astro
import { supabase } from '../../lib/supabase';

// DINAMIS: Menggunakan server-side rendering agar data langsung ter-update & terhapus secara real-time
export const prerender = false; 

let notifikasi = '';
let tipeNotifikasi = ''; // 'sukses' atau 'gagal'

// 1. LOGIKA BACKEND: Menangkap kiriman form & aksi hapus dari sisi server
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const tipeForm = formData.get('tipe_form');

    // JALUR A: HAPUS ARTIKEL BERITA
    if (tipeForm === 'hapus_berita') {
      const idBerita = formData.get('id_berita');
      const { error } = await supabase
        .from('berita')
        .delete()
        .eq('id', idBerita);

      if (error) throw error;
      notifikasi = 'Artikel berita berhasil dihapus secara permanen!';
      tipeNotifikasi = 'sukses';
    } 
    
    // JALUR B: HAPUS BANNER IKLAN
    else if (tipeForm === 'hapus_iklan') {
      const idIklan = formData.get('id_iklan');
      const { error } = await supabase
        .from('iklan')
        .delete()
        .eq('id', idIklan);

      if (error) throw error;
      notifikasi = 'Data iklan komersial berhasil dihapus!';
      tipeNotifikasi = 'sukses';
    }

    // JALUR C: INPUT ARTIKEL BERITA BARU
    else if (tipeForm === 'berita') {
      const judul = formData.get('judul');
      const slug = formData.get('slug');
      const kategori = formData.get('kategori');
      const penulis = formData.get('penulis');
      const gambar_url = formData.get('gambar_url');
      const pdf_url = formData.get('pdf_url'); 
      const ringkasan = formData.get('ringkasan');
      const isi_konten = formData.get('isi_konten');

      const { error } = await supabase
        .from('berita')
        .insert([
          { 
            judul, 
            slug, 
            kategori, 
            penulis: penulis || 'Redaksi', 
            gambar_url,
            pdf_url, 
            ringkasan, 
            isi_konten,
            created_at: new Date().toISOString()
          }
        ]);

      if (error) throw error;
      notifikasi = 'Artikel berita baru berhasil diterbitkan!';
      tipeNotifikasi = 'sukses';
    } 
    
    // JALUR D: INPUT BANNER IKLAN BARU
    else if (tipeForm === 'iklan') {
      const konten_teks = formData.get('konten_teks');
      const link_tujuan = formData.get('link_tujuan');
      const gambar_url = formData.get('gambar_url'); // Tautan Gambar Banner Iklan
      const pdf_url = formData.get('pdf_url');     // Tautan Lampiran PDF Kontrak/Dokumen Iklan
      const posisi = formData.get('posisi');
      const status = formData.get('status');

      const { error } = await supabase
        .from('iklan')
        .insert([
          { 
            konten_teks, 
            link_tujuan, 
            gambar_url,
            pdf_url,
            posisi, 
            status,
            created_at: new Date().toISOString()
          }
        ]);

      if (error) throw error;
      notifikasi = 'Iklan komersial berhasil dipasang!';
      tipeNotifikasi = 'sukses';
    }
  } catch (err: any) {
    notifikasi = 'Gagal memproses data: ' + err.message;
    tipeNotifikasi = 'gagal';
  }
}

// 2. AMBIL DATA UNTUK TABEL MANAGEMENT
const { data: daftarBerita } = await supabase
  .from('berita')
  .select('*')
  .order('created_at', { ascending: false });

const { data: daftarIklan } = await supabase
  .from('iklan')
  .select('*')
  .order('created_at', { ascending: false });
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nusa-Media Control Center</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://w3.org viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📰</text></svg>">
    <script src="https://tailwindcss.com"></script>
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-gray-100 p-4 md:p-8 text-gray-900 min-h-screen" style="font-family: 'Roboto', sans-serif;">

    <div class="max-w-4xl mx-auto space-y-6">
      
      <!-- HEADER PANEL -->
      <div class="bg-slate-900 text-white p-6 rounded-2xl shadow-sm border-b-4 border-red-600 flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-black tracking-tight"># Nusa-Media Control Center</h1>
          <p class="text-xs text-gray-400 mt-1 uppercase tracking-wider">Sistem Input Berita, File PDF & Manajemen Iklan Dinamis</p>
        </div>
        <a href="/" class="text-xs bg-red-600 hover:bg-red-700 text-white font-bold px-3 py-2 rounded-lg transition">Lihat Beranda ↗</a>
      </div>

      <!-- NOTIFIKASI AKTIVITAS -->
      {notifikasi && (
        <div class={`p-4 rounded-xl font-bold text-sm shadow-xs flex justify-between items-center ${tipeNotifikasi === 'sukses' ? 'bg-emerald-50 border border-emerald-300 text-emerald-800' : 'bg-rose-50 border border-rose-300 text-rose-800'}`}>
          <span>{notifikasi}</span>
          <button onclick="this.parentElement.remove()" class="text-xs font-black opacity-50 hover:opacity-100">✕</button>
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- FORM 1: INPUT BERITA BARU -->
        <div class="lg:col-span-2 bg-white p-6 rounded-2xl border border-gray-200 shadow-xs">
          <h2 class="text-lg font-black text-slate-800 mb-4 pb-2 border-b">📰 Tulis Artikel Berita Baru</h2>
          <form method="POST" class="space-y-4">
            <input type="hidden" name="tipe_form" value="berita" />
            
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Judul Utama Berita</label>
              <input type="text" id="judul" name="judul" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Ketik judul berita terhangat..." required />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">URL Slug (Otomatis Terisi)</label>
              <input type="text" id="slug" name="slug" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none bg-gray-100 text-gray-600" placeholder="otomatis-terbentuk-dari-judul" readonly required />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Kategori Liputan</label>
                <select name="kategori" class="w-full border rounded-lg px-3 py-2 text-sm bg-gray-50 focus:outline-none focus:border-red-500">
                  <option value="Politik & Ekonomi">Politik & Ekonomi</option>
                  <option value="Teknologi Digital">Teknologi Digital</option>
                  <option value="Nusantara Global">Nusantara Global</option>
                  <option value="Olahraga & Gaya Hidup">Olahraga & Gaya Hidup</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Nama Penulis / Inisial</label>
                <input type="text" name="penulis" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Redaksi" />
              </div>
            </div>
            
            <!-- MULTIMEDIA BERITA -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 bg-gray-50 p-3 rounded-xl border border-dashed border-gray-300">
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">🔗 URL Gambar Berita</label>
                <input type="url" name="gambar_url" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500 bg-white" placeholder="https://unsplash.com" />
              </div>
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">📂 URL Lampiran PDF Berita</label>
                <input type="url" name="pdf_url" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500 bg-white" placeholder="https://supabase.com" />
              </div>
            </div>

            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Ringkasan Singkat (Lead)</label>
              <input type="text" name="ringkasan" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Ketik 1 kalimat ringkasan utama..." required />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Isi Konten Berita Lengkap</label>
              <textarea name="isi_konten" rows="5" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Ketik isi berita lengkap di sini..." required></textarea>
            </div>
            <button type="submit" class="w-full bg-slate-900 hover:bg-slate-800 text-white font-bold py-3 rounded-xl text-sm transition shadow-xs">
              Terbitkan Berita Sekarang 🚀
            </button>
          </form>
        </div>

        <!-- FORM 2: INPUT IKLAN SPONSOR -->
        <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-xs h-fit">
          <h2 class="text-lg font-black text-slate-800 mb-4 pb-2 border-b">💎 Pasang Iklan Sponsor</h2>
          <form method="POST" class="space-y-4">
            <input type="hidden" name="tipe_form" value="iklan" />

            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Teks Ucapan / Judul Iklan</label>
              <input type="text" name="konten_teks" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Ketik kalimat ucapan..." required />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Link Tujuan Iklan (URL Klik)</label>
              <input type="url" name="link_tujuan" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="https://perusahaan.com" required />
            </div>

            <!-- MODIFIKASI MULTIMEDIA IKLAN: BANNER & PDF -->
            <div class="bg-gray-50 p-3 rounded-xl border border-dashed border-gray-300 space-y-2">
              <div>
                <label class="block text-[10px] font-bold uppercase text-gray-500 mb-0.5">🔗 URL Gambar Banner Iklan</label>
                <input type="url" name="gambar_url" class="w-full border border-gray-300 rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-red-500 bg-white" placeholder="https://link-foto-iklan.jpg" />
              </div>
              <div>
                <label class="block text-[10px] font-bold uppercase text-gray-500 mb-0.5">📂 URL PDF Kontrak/Media (Opsional)</label>
                <input type="url" name="pdf_url" class="w-full border border-gray-300 rounded-lg px-2 py-1.5 text-xs focus:outline-none focus:border-red-500 bg-white" placeholder="https://link-kontrak.pdf" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Posisi Banner</label>
                <select name="posisi" class="w-full border rounded-lg px-2 py-1.5 text-xs bg-gray-50 focus:outline-none focus:border-red-500">
                  <option value="detail_atas">Banner Atas (Tengah)</option>
                  <option value="sidebar_atas">Kolom Kanan (Sidebar)</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Status</label>
                <select name="status" class="w-full border rounded-lg px-2 py-1.5 text-xs bg-gray-50 focus:outline-none focus:border-red-500">
                  <option value="aktif">Langsung Tayang</option>
                  <option value="nonaktif">Draft (Sembunyikan)</option>
                </select>
              </div>
            </div>
            
            <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 rounded-xl text-sm transition shadow-xs">
              Pasang Iklan Komersial Sekarang 💸
            </button>
          </form>
        </div>

      </div>

      <!-- TABEL MANAJEMEN ARSIP BERITA -->
      <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-xs">
        <h2 class="text-lg font-black text-slate-800 mb-4 pb-2 border-b flex justify-between items-center">
          <span>🗂️ Tabel Manajerial Arsip Berita</span>
          <span class="text-xs bg-slate-100 border px-2.5 py-1 rounded-full font-bold text-gray-500">Total: {daftarBerita?.length || 0}</span>
        </h2>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-sm">
            <thead>
              <tr class="bg-gray-50 border-b text-gray-500 font-bold text-xs uppercase tracking-wider">
                <th class="py-3 px-4">Judul & Detail Info</th>
                <th class="py-3 px-4">Kategori</th>
                <th class="py-3 px-4 text-center">Media Berkas</th>
                <th class="py-3 px-4 text-right">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y text-gray-700">
              {daftarBerita && daftarBerita.length > 0 ? (
                daftarBerita.map((berita) => (
                  <tr class="hover:bg-gray-50/50 transition duration-150">
                    <td class="py-4 px-4 max-w-xs md:max-w-md">
                      <div class="font-bold text-slate-900 truncate">{berita.judul}</div>
                      <div class="text-[11px] text-gray-400 mt-0.5">ID: {berita.id} | Penulis: {berita.penulis}</div>
                    </td>
                    <td class="py-4 px-4">
                      <span class="text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded bg-red-50 border border-red-200 text-red-600">
                        {berita.kategori || 'Fokus'}
                      </span>
                    </td>
                    <td class="py-4 px-4 text-center">
                      <div class="flex justify-center gap-2">
                        {berita.gambar_url && <span title="Ada Gambar">🖼️</span>}
                        {berita.pdf_url && <span title="Ada PDF">📄</span>}
                      </div>
                    </td>
                    <td class="py-4 px-4 text-right">
                      <form method="POST" onsubmit="return confirm('Hapus artikel berita secara permanen?');" class="inline">
                        <input type="hidden" name="tipe_form" value="hapus_berita" />
                        <input type="hidden" name="id_berita" value={berita.id} />
                        <button type="submit" class="bg-red-50 border border-red-300 hover:bg-red-600 hover:text-white text-red-600 font-bold text-xs px-3 py-1.5 rounded-lg transition duration-150">🗑️ Hapus</button>
                      </form>
                    </td>
                  </tr>
                ))
              ) : (
                <tr><td colspan="4" class="py-6 text-center text-gray-400 italic">Belum ada artikel berita.</td></tr>
              )}
            </tbody>
          </table>
        </div>
      </div>

      <!-- NEW FORM TABEL: MANAJEMEN MONITORING BANNER IKLAN SPONSOR -->
      <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-xs">
        <h2 class="text-lg font-black text-slate-800 mb-4 pb-2 border-b flex justify-between items-center">
          <span>📊 Monitoring Slot Penayangan Iklan Aktif</span>
          <span class="text-xs bg-emerald-50 border border-emerald-200 px-2.5 py-1 rounded-full font-bold text-emerald-700">Total: {daftarIklan?.length || 0} Banner</span>
        </h2>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-sm">
            <thead>
              <tr class="bg-gray-50 border-b text-gray-500 font-bold text-xs uppercase tracking-wider">
                <th class="py-3 px-4">Teks Ucapan / Klien Sponsor</th>
                <th class="py-3 px-4">Posisi Slot</th>
                <th class="py-3 px-4 text-center">Berkas Iklan</th>
                <th class="py-3 px-4 text-right">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y text-gray-700">
              {daftarIklan && daftarIklan.length > 0 ? (
                daftarIklan.map((iklan) => (
                  <tr class="hover:bg-gray-50/50 transition duration-150">
                    <td class="py-4 px-4 max-w-xs truncate">
                      <div class="font-bold text-slate-900">{iklan.konten_teks}</div>
                      <a href={iklan.link_tujuan} target="_blank" class="text-[11px] text-emerald-600 hover:underline block truncate mt-0.5">{iklan.link_tujuan}</a>
                    </td>
                    <td class="py-4 px-4">
                      <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded bg-slate-100 border border-slate-300 text-slate-700">
                        {iklan.posisi === 'detail_atas' ? '🖥️ Banner Atas' : '📱 Sidebar'}
                      </span>
                    </td>
                    <td class="py-4 px-4 text-center">
                      <div class="flex justify-center gap-2">
                        {iklan.gambar_url && <span title="Ada Banner Foto">🖼️</span>}
                        {iklan.pdf_url && <span title="Ada Dokumen PDF">📄</span>}
                      </div>
                    </td>
                    <td class="py-4 px-4 text-right">
                      <form method="POST" onsubmit="return confirm('Apakah Anda yakin ingin mencopot dan menghapus banner iklan sponsor ini?');" class="inline">
                        <input type="hidden" name="tipe_form" value="hapus_iklan" />
                        <input type="hidden" name="id_iklan" value={iklan.id} />
                        <button type="submit" class="bg-rose-50 border border-rose-300 hover:bg-rose-600 hover:text-white text-rose-600 font-bold text-xs px-3 py-1.5 rounded-lg transition duration-150">
                          🗑️ Turunkan Iklan
                        </button>
                      </form>
                    </td>
                  </tr>
                ))
              ) : (
                <tr><td colspan="4" class="py-6 text-center text-gray-400 italic">Belum ada space iklan yang terisi.</td></tr>
              )}
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- LOGIKA BROWSER CLIENT-SIDE -->
    <script>
      const inputJudul = document.getElementById('judul');
      const inputSlug = document.getElementById('slug');

      inputJudul?.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        if (inputSlug) {
          (inputSlug as HTMLInputElement).value = target.value
            .toLowerCase()
            .replace(/[^a-z0-9\s-]/g, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .trim();
        }
      });
    </script>
  </body>
</html>
