---
// src/pages/admin-rahasia-99/index.astro
export const prerender = true; // 👈 MENGGUNAKAN MODE STATIS AGAR SINKRON DENGAN ARCHITECTURE UTAMA

import { supabase } from '../../lib/supabase';

let notifikasi = '';
let tipeNotifikasi = ''; // 'sukses' atau 'gagal'

// 1. LOGIKA BACKEND: Menangkap kiriman form & aksi hapus dari sisi server
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const tipeForm = formData.get('tipe_form');

    // JALUR A: HAPUS ARTIKEL BERITA
    if (tipeForm === 'hapus_berita') {
      const idBerita = formData.get('id_berita');
      const { error } = await supabase
        .from('berita')
        .delete()
        .eq('id', idBerita);

      if (error) throw error;
      notifikasi = 'Artikel berita berhasil dihapus secara permanen!';
      tipeNotifikasi = 'sukses';
    } 
    
    // JALUR B: HAPUS BANNER IKLAN
    else if (tipeForm === 'hapus_iklan') {
      const idIklan = formData.get('id_iklan');
      const { error } = await supabase
        .from('iklan')
        .delete()
        .eq('id', idIklan);

      if (error) throw error;
      notifikasi = 'Data iklan komersial berhasil dihapus!';
      tipeNotifikasi = 'sukses';
    }

    // JALUR C: INPUT ARTIKEL BERITA BARU
    else if (tipeForm === 'berita') {
      const judul = formData.get('judul');
      const slug = formData.get('slug');
      const kategori = formData.get('kategori');
      const penulis = formData.get('penulis');
      const gambar_url = formData.get('gambar_url');
      const pdf_url = formData.get('pdf_url'); 
      const ringkasan = formData.get('ringkasan');
      const isi_konten = formData.get('isi_konten');

      const { error } = await supabase
        .from('berita')
        .insert([
          { 
            judul, 
            slug, 
            kategori, 
            penulis: penulis || 'Redaksi', 
            gambar_url,
            pdf_url, 
            ringkasan, 
            isi_konten,
            created_at: new Date().toISOString()
          }
        ]);

      if (error) throw error;
      notifikasi = 'Artikel berita baru berhasil diterbitkan!';
      tipeNotifikasi = 'sukses';
    } 
    
    // JALUR D: INPUT BANNER IKLAN BARU
    else if (tipeForm === 'iklan') {
      const konten_teks = formData.get('konten_teks');
      const link_tujuan = formData.get('link_tujuan');
      const gambar_url_iklan = formData.get('gambar_url'); 
      const pdf_url_iklan = formData.get('pdf_url');     
      const posisi = formData.get('posisi');
      const status = formData.get('status');

      const { error } = await supabase
        .from('iklan')
        .insert([
          { 
            konten_teks, 
            link_tujuan, 
            gambar_url: gambar_url_iklan,
            pdf_url: pdf_url_iklan,
            posisi, 
            status,
            created_at: new Date().toISOString()
          }
        ]);

      if (error) throw error;
      notifikasi = 'Iklan komersial berhasil dipasang!';
      tipeNotifikasi = 'sukses';
    }
  } catch (err: any) {
    notifikasi = 'Gagal memproses data: ' + err.message;
    tipeNotifikasi = 'gagal';
  }
}

// 2. AMBIL DATA UNTUK TABEL MANAGEMENT
const { data: daftarBerita } = await supabase
  .from('berita')
  .select('*')
  .order('created_at', { ascending: false });

const { data: daftarIklan } = await supabase
  .from('iklan')
  .select('*')
  .order('created_at', { ascending: false });
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nusa-Media Control Center</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://w3.org viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📰</text></svg>">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-gray-100 p-4 md:p-8 text-gray-900 min-h-screen" style="font-family: 'Roboto', sans-serif;">

    <div class="max-w-4xl mx-auto space-y-6">
      
      <!-- HEADER PANEL -->
      <div class="bg-slate-900 text-white p-6 rounded-2xl shadow-sm border-b-4 border-red-600 flex justify-between items-center">
        <div>
          <h1 class="text-2xl font-black tracking-tight"># Nusa-Media Control Center</h1>
          <p class="text-xs text-gray-400 mt-1 uppercase tracking-wider">Sistem Input Berita, File PDF & Manajemen Iklan Dinamis</p>
        </div>
        <a href="/" class="text-xs bg-red-600 hover:bg-red-700 text-white font-bold px-3 py-2 rounded-lg transition">Lihat Beranda ↗</a>
      </div>

      <!-- NOTIFIKASI AKTIVITAS -->
      {notifikasi && (
        <div class={`p-4 rounded-xl font-bold text-sm shadow-xs flex justify-between items-center ${tipeNotifikasi === 'sukses' ? 'bg-emerald-50 border border-emerald-300 text-emerald-800' : 'bg-rose-50 border border-rose-300 text-rose-800'}`}>
          <span>{notifikasi}</span>
          <button onclick="this.parentElement.remove()" class="text-xs font-black opacity-50 hover:opacity-100">✕</button>
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- FORM 1: INPUT BERITA BARU -->
        <div class="lg:col-span-2 bg-white p-6 rounded-2xl border border-gray-200 shadow-xs">
          <h2 class="text-lg font-black text-slate-800 mb-4 pb-2 border-b">📰 Tulis Artikel Berita Baru</h2>
          <form method="POST" class="space-y-4">
            <input type="hidden" name="tipe_form" value="berita" />
            
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Judul Utama Berita</label>
              <input type="text" id="judul" name="judul" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Ketik judul berita terhangat..." required />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">URL Slug (Otomatis Terisi)</label>
              <input type="text" id="slug" name="slug" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none bg-gray-100 text-gray-600" placeholder="otomatis-terbentuk-dari-judul" readonly required />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Kategori Liputan</label>
                <select name="kategori" class="w-full border rounded-lg px-3 py-2 text-sm bg-gray-50 focus:outline-none focus:border-red-500">
                  <option value="Politik & Ekonomi">Politik & Ekonomi</option>
                  <option value="Teknologi Digital">Teknologi Digital</option>
                  <option value="Nusantara Global">Nusantara Global</option>
                  <option value="Olahraga & Gaya Hidup">Olahraga & Gaya Hidup</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Nama Penulis / Inisial</label>
                <input type="text" name="penulis" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Redaksi" />
              </div>
            </div>
            
            <!-- MULTIMEDIA BERITA -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 bg-gray-50 p-3 rounded-xl border border-dashed border-gray-300">
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">🔗 URL Gambar Berita</label>
                <input type="url" name="gambar_url" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500 bg-white" placeholder="https://unsplash.com" />
              </div>
              <div>
                <label class="block text-xs font-bold uppercase text-gray-500 mb-1">📂 URL Lampiran PDF Berita</label>
                <input type="url" name="pdf_url" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-xs focus:outline-none focus:border-red-500 bg-white" placeholder="https://supabase.com" />
              </div>
            </div>

            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Ringkasan Singkat (Lead)</label>
              <input type="text" name="ringkasan" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Ketik 1 kalimat ringkasan utama..." required />
            </div>
            <div>
              <label class="block text-xs font-bold uppercase text-gray-500 mb-1">Isi Konten Berita Lengkap</label>
              <textarea name="isi_konten" rows="5" class="w-full border rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-red-500 bg-gray-50" placeholder="Ketik isi berita lengkap di sini..." required></textarea>
            </div>
            
            <!-- BUTTON TERBITKAN BERITA DENGAN ALERT NOTIFIKASI -->
            <button type="submit" onclick="alert('Berita terkirim! Website Nusa-Media sedang diperbarui otomatis di internet dalam 30 detik...')" class="w-full bg-slate-900 hover:bg-slate-800 text-white font-bold py-3 rounded-xl text-sm transition shadow-xs">
              Terbitkan Berita Sekarang 🚀
            </button>
          </form>
        </div>

        <!-- FORM 2: INPUT IKLAN SPONSOR -->
        <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-xs h-fit">
          <h2 class="text-lg font-black text-slate-800 mb-4 pb-2 border-b">💎 Pasang Iklan Sponsor</h2>
