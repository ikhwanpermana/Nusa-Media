---
// src/pages/admin-rahasia-99/index.astro
export const prerender = true; // Menggunakan sistem statis sisi klien agar bebas 404 Vercel/Cloudflare
import '../../styles/global.css';
---
<html lang="id" class="h-full bg-[#070A13]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nusa Engine — Core Executive Dashboard</title>
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Inter', sans-serif; }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #0B0F19; }
      ::-webkit-scrollbar-thumb { background: #1E293B; border-radius: 99px; }
      ::-webkit-scrollbar-thumb:hover { background: #334155; }
    </style>
  </head>
  <body class="text-slate-200 min-h-screen antialiased bg-[#070A13] selection:bg-indigo-500 selection:text-white">

    <!-- TOP NAVIGATION BAR -->
    <header class="sticky top-0 z-50 w-full border-b border-slate-800/80 bg-[#0B132B]/80 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="w-9 h-9 bg-gradient-to-tr from-indigo-600 to-violet-500 rounded-xl flex items-center justify-center text-white font-extrabold text-lg shadow-md shadow-indigo-500/20">N</div>
          <div>
            <h1 class="text-sm font-bold tracking-tight text-white flex items-center gap-2">
              Nusa Media Engine
              <span class="text-[10px] text-indigo-400 bg-indigo-500/10 px-2 py-0.5 rounded border border-indigo-500/20 font-mono font-medium">CORE V2.5</span>
            </h1>
            <p class="text-[10px] text-slate-400 font-medium uppercase tracking-wide">Enterprise Ad & Content Management</p>
          </div>
        </div>
        <div class="flex items-center space-x-4">
          <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
            <span class="w-1.5 h-1.5 mr-2 bg-emerald-400 rounded-full animate-pulse"></span> Network Synced
          </span>
          <a href="/" class="inline-flex items-center justify-center px-4 py-1.5 text-xs font-bold text-slate-300 bg-slate-800/80 hover:bg-slate-700 border border-slate-700 rounded-xl transition">Live Site ↗</a>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
      
      <!-- TOAST NOTIFIKASI MELAYANG -->
      <div id="notif-box" class="hidden fixed top-20 right-4 sm:right-8 z-50 max-w-md w-fit p-4 rounded-xl shadow-xl border backdrop-blur-md transition-all duration-300 transform scale-95 flex items-center space-x-3">
        <span id="notif-icon" class="text-lg"></span>
        <span id="notif-text" class="text-sm font-semibold"></span>
      </div>

      <!-- TATA LETAK 2 KOLOM FORMULIR INPUT -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- FORM BERITA -->
        <div class="bg-[#0B132B] rounded-2xl border border-slate-800/80 shadow-xl p-6 space-y-5">
          <h2 class="text-xs font-bold text-indigo-400 uppercase tracking-widest border-b border-slate-800 pb-3 flex items-center gap-2">📰 Publisher Studio</h2>
          <form id="form-berita" class="space-y-4">
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Judul Utama Berita</label>
              <input type="text" id="judul" class="w-full bg-[#070A13] border border-slate-800 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-indigo-500 transition" placeholder="Masukkan headline berita..." required />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Sistem URL Slug</label>
              <input type="text" id="slug" class="w-full bg-[#070A13]/50 border border-slate-800 rounded-xl px-4 py-2.5 text-sm font-mono text-indigo-400/80 focus:outline-none" readonly required />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Kategori Konten</label>
                <select id="kategori" class="w-full bg-[#070A13] border border-slate-800 rounded-xl px-3 py-2.5 text-sm text-slate-300 focus:outline-none focus:border-indigo-500">
                  <option value="Politik & Ekonomi">Politik & Ekonomi</option>
                  <option value="Teknologi Digital">Teknologi Digital</option>
                  <option value="Nusantara Global">Nusantara Global</option>
                  <option value="Olahraga & Gaya Hidup">Olahraga & Gaya Hidup</option>
                </select>
              </div>
              <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Penulis</label>
                <input type="text" id="penulis" class="w-full bg-[#070A13] border border-slate-800 rounded-xl px-4 py-2.5 text-sm text-white" placeholder="Redaksi Nusa-Media" />
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">🔗 URL Gambar Asset</label>
              <input type="url" id="gambar_url" class="w-full bg-[#070A13] border border-slate-800 rounded-xl px-4 py-2.5 text-xs font-mono text-slate-300" placeholder="https://..." required />
            </div>
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Isi Konten Berita</label>
              <textarea id="isi_konten" rows="4" class="w-full bg-[#070A13] border border-slate-800 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-indigo-500" placeholder="Tulis isi berita..." required></textarea>
            </div>
            <button type="submit" id="btn-berita" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 rounded-xl text-xs tracking-widest uppercase cursor-pointer">Siarkan Berita 🚀</button>
          </form>
        </div>

        <!-- FORM IKLAN -->
        <div class="bg-[#0B132B] rounded-2xl border border-slate-800/80 shadow-xl p-6 space-y-5">
          <h2 class="text-xs font-bold text-violet-400 uppercase tracking-widest border-b border-slate-800 pb-3 flex items-center gap-2">💰 Ad Monetization Console</h2>
          <form id="form-iklan" class="space-y-4">
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Nama Sponsor Client</label>
              <input type="text" id="iklan-nama" class="w-full bg-[#070A13] border border-slate-800 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-violet-500" placeholder="Contoh: Sponsor Banner Idul Fitri" required />
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Zona Periklanan</label>
                <select id="iklan-zona" class="w-full bg-[#070A13] border border-slate-800 rounded-xl px-3 py-2.5 text-sm text-slate-300 focus:outline-none focus:border-violet-500">
                  <option value="header_top">Sticky Header Top (728x90)</option>
                  <option value="sidebar_right">Sidebar Right Banner (300x250)</option>
                  <option value="sidebar_sticky">Sidebar Lower Sticky (300x600)</option>
                  <option value="in_article">In-Article Center 1</option>
                  <option value="in_article_2">In-Article Center 2</option>
                  <option value="footer_banner">Footer Bottom Wide</option>
                  <option value="popup_float">Popup Floating Ad Box</option>
                </select>
              </div>
              <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Destination URL</label>
                <input type="url" id="iklan-link" class="w-full bg-[#070A13] border border-slate-800 rounded-xl px-4 py-2.5 text-sm text-white" placeholder="https://..." required />
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">🔗 URL Gambar Kreatif Banner</label>
              <input type="url" id="iklan-gambar" class="w-full bg-[#070A13] border border-slate-800 rounded-xl px-4 py-2.5 text-xs font-mono text-slate-300" placeholder="https://..." required />
            </div>
            <button type="submit" id="btn-iklan" class="w-full bg-violet-600 hover:bg-violet-500 text-white font-bold py-3 rounded-xl text-xs tracking-widest uppercase cursor-pointer">Aktifkan Slot Iklan 💵</button>
          </form>
        </div>
      </div>

      <!-- ── INDUSTRIAL MANAGEMENT CENTER: DAFTAR MONITORING MODERN & PROFESIONAL ── -->
      <div class="space-y-6">
        <!-- MONITORING LIVE BERITA MASAL -->
        <div class="bg-[#0B132B] border border-slate-800/80 rounded-2xl shadow-xl overflow-hidden">
          <div class="px-6 py-4 border-b border-slate-800 bg-slate-900/20 flex justify-between items-center">
            <h3 class="text-xs font-bold uppercase tracking-widest text-slate-300 flex items-center gap-2">📁 Manajer Berita Aktif</h3>
            <span id="count-berita" class="text-xs font-mono font-bold text-indigo-400 bg-indigo-500/10 px-3 py-1 rounded-xl border border-indigo-500/20">0 Berita</span>
          </div>
          <div class="overflow-x-auto w-full">
