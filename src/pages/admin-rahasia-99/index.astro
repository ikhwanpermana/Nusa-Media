---
// src/pages/admin-rahasia-99/index.astro
export const prerender = true; // Menggunakan sistem statis sisi klien agar bebas 404 Vercel
---
<html lang="id" class="h-full bg-slate-50">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nusa-Media | Ad & Content Console</title>
    <!-- Tailwind CSS -->
    <script src="https://jsdelivr.net"></script>
    <!-- Google Fonts: Inter untuk tampilan UI Modern & Profesional -->
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Inter', sans-serif; }
    </style>
  </head>
  <body class="text-slate-900 min-h-screen antialiased bg-slate-50/50">

    <!-- TOP NAVIGATION BAR -->
    <header class="sticky top-0 z-40 w-full border-b border-slate-200 bg-white/80 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <div class="w-9 h-9 bg-indigo-600 rounded-xl flex items-center justify-center text-white font-bold text-lg shadow-sm shadow-indigo-500/30">N</div>
          <div>
            <h1 class="text-sm font-semibold tracking-tight text-slate-900">Nusa-Media Management</h1>
            <p class="text-[11px] text-slate-500 font-medium tracking-wide uppercase">Enterprise Ad Server &bull; v2.1</p>
          </div>
        </div>
        <div class="flex items-center space-x-4">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-200/60">
            <span class="w-1.5 h-1.5 mr-1.5 bg-emerald-500 rounded-full animate-pulse"></span> Connected to Cloud
          </span>
          <a href="/" class="inline-flex items-center justify-center px-3.5 py-1.5 text-xs font-semibold text-slate-700 bg-white border border-slate-300 rounded-lg shadow-xs hover:bg-slate-50 hover:text-slate-900 transition-all duration-200">
            Ke Beranda <span class="ml-1 text-slate-400">↗</span>
          </a>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      
      <!-- NOTIFIKASI TOAST (Melayang di kanan atas secara elegan jika muncul) -->
      <div id="notif-box" class="hidden fixed top-20 right-4 sm:right-8 z-50 max-w-md w-full p-4 rounded-xl shadow-lg border backdrop-blur-md transition-all duration-300 transform translate-y-0 flex items-center justify-between">
        <div class="flex items-center space-x-3">
          <span id="notif-icon" class="text-lg"></span>
          <span id="notif-text" class="text-sm font-medium"></span>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- KOLOM KIRI & TENGAH: FORMS -->
        <div class="lg:col-span-2 space-y-8">
          
          <!-- FORM INPUT BERITA -->
          <div class="bg-white rounded-2xl border border-slate-200 shadow-xs overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
              <h2 class="text-sm font-bold text-slate-800 uppercase tracking-wider flex items-center gap-2">
                <span>📰</span> Publisher Studio
              </h2>
              <span class="text-xs text-slate-400 font-medium">Konten Berita</span>
            </div>
            <form id="form-berita" class="p-6 space-y-5">
              <div>
                <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Judul Utama Berita</label>
                <input type="text" id="judul" class="w-full border border-slate-200 rounded-xl px-3.5 py-2 text-sm focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 bg-white transition" placeholder="Masukkan judul berita yang menarik..." required />
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Sistem URL Slug (Otomatis)</label>
                <div class="relative">
                  <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-xs text-slate-400 font-mono bg-slate-50 border-r border-slate-200 rounded-l-xl px-2">/berita/</span>
                  <input type="text" id="slug" class="w-full border border-slate-200 rounded-xl pl-22 pr-3.5 py-2 text-sm bg-slate-50 font-mono text-slate-500 focus:outline-none" readonly required />
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Kategori Konten</label>
                  <select id="kategori" class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 text-slate-700 transition">
                    <option value="Politik & Ekonomi">Politik & Ekonomi</option>
                    <option value="Teknologi Digital">Teknologi Digital</option>
                    <option value="Nusantara Global">Nusantara Global</option>
                    <option value="Olahraga & Gaya Hidup">Olahraga & Gaya Hidup</option>
                  </select>
                </div>
                <div>
                  <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Kredensial Penulis</label>
                  <input type="text" id="penulis" class="w-full border border-slate-200 rounded-xl px-3.5 py-2 text-sm bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition" placeholder="Redaksi Nusa-Media" />
                </div>
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">🔗 URL Gambar Sampul (Media Asset)</label>
                <input type="url" id="gambar_url" class="w-full border border-slate-200 rounded-xl px-3.5 py-2 text-xs font-mono bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition" placeholder="https://unsplash.com..." required />
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Isi Berita Lengkap (Rich Body Content)</label>
                <textarea id="isi_konten" rows="6" class="w-full border border-slate-200 rounded-xl px-3.5 py-2.5 text-sm bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition placeholder-slate-400" placeholder="Tulis atau tempel artikel lengkap di sini..." required></textarea>
              </div>
              <div class="pt-2">
                <button type="submit" id="btn-berita" class="w-full bg-slate-900 hover:bg-slate-800 text-white font-semibold py-2.5 px-4 rounded-xl text-xs transition-all duration-200 shadow-sm hover:shadow-md cursor-pointer tracking-wider uppercase">
                  Terbitkan Berita Ke Cloud 🚀
                </button>
              </div>
            </form>
          </div>

          <!-- FORM INPUT BANNER IKLAN -->
          <div class="bg-white rounded-2xl border border-slate-200 shadow-xs overflow-hidden">
            <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
              <h2 class="text-sm font-bold text-slate-800 uppercase tracking-wider flex items-center gap-2">
                <span>💰</span> Ad Monetization Console
              </h2>
              <span class="text-xs text-slate-400 font-medium">Slot Komersial</span>
            </div>
            <form id="form-iklan" class="p-6 space-y-5">
              <div>
                <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Deskripsi / Nama Client Sponsor</label>
                <input type="text" id="konten_teks" class="w-full border border-slate-200 rounded-xl px-3.5 py-2 text-sm bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition" placeholder="Contoh: Banner Samping Telkomsel Ramadhan campaign" required />
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Format Rendering Konten</label>
                  <select id="format_iklan" class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm bg-amber-50/60 font-bold text-amber-900 focus:outline-none focus:ring-2 focus:ring-amber-200 transition">
                    <option value="Gambar">🖼️ File Gambar / Foto Banner</option>
                    <option value="PDF">📂 Berkas PDF Document Tab</option>
                    <option value="HTML">💻 Embed Kode HTML / AdSense</option>
                  </select>
                </div>
                <div>
                  <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1.5">Posisi Tata Letak (Ad Placement)</label>
                  <select id="posisi" class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm bg-white focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 text-slate-700 transition">
                    <option value="Header Utama">Atas Artikel (Header Banner)</option>
                    <option value="Tengah Artikel">Bawah Artikel (Mid-Page Banner)</option>
                    <option value="Sidebar Kanan">Atas Sidebar Kanan (Sticky Widget)</option>
                  </select>
