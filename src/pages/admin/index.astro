---
// PERBAIKAN JALUR IMPOR: Menggunakan ../../ karena berada di dalam sub-folder admin/
import { supabase } from '../../lib/supabase';
export const prerender = false;

let pesanSukses = "";
let pesanGagal = "";

// 1. PROSES AKSI DATABASE (Dijalankan di server Node.js)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const aksi = formData.get('aksi')?.toString();

    // AKSI TAMBAH BERITA SUPER LENGKAP
    if (aksi === 'tambah') {
      const judul = formData.get('judul')?.toString();
      const slug = formData.get('slug')?.toString();
      const kategori = formData.get('kategori')?.toString();
      const penulis = formData.get('penulis')?.toString();
      const ringkasan_pendek = formData.get('ringkasan_pendek')?.toString();
      const isi_artikel = formData.get('isi_artikel')?.toString();
      const gambar_url = formData.get('gambar_url')?.toString();
      const youtube_url = formData.get('youtube_url')?.toString();
      const tanggal_input = formData.get('tanggal_input')?.toString() || new Date().toISOString().split('T')[0];

      // Kirim data lengkap ke tabel 'posts' di Supabase
      const { error } = await supabase.from('posts').insert([
        { 
          judul, 
          slug, 
          kategori, 
          penulis, 
          ringkasan: ringkasan_pendek, 
          isi_artikel, 
          gambar_url, 
          youtube_url, 
          created_at: tanggal_input 
        }
      ]);

      if (error) {
        pesanGagal = error.message;
      } else {
        pesanSukses = "🚀 Berita Lengkap Baru Berhasil Diterbitkan!";
      }
    }

    // AKSI HAPUS BERITA LANGSUNG
    if (aksi === 'hapus') {
      const idHapus = formData.get('id')?.toString();
      const { error } = await supabase.from('posts').delete().eq('id', idHapus);
      
      if (error) {
        pesanGagal = error.message;
      } else {
        pesanSukses = "🗑️ Berita berhasil dihapus dari database!";
      }
    }
  } catch (e) {
    pesanGagal = "Terjadi kesalahan koneksi server lokal.";
  }
}

// 2. AMBIL DATA ARSIP BERITA LIVE
const { data: artikel } = await supabase
  .from('posts')
  .select('*')
  .order('id', { ascending: false });
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Panel Admin - Berita Nusa Media (Dark Mode)</title>

  <!-- KODE CSS: Memaksa warna gelap gulita & kotak rapi -->
  <style is:global>
    body {
      background-color: #0b1329 !important; /* Hitam kebiruan pekat */
      color: #f8fafc !important;            /* Teks putih terang */
      font-family: ui-sans-serif, system-ui, sans-serif;
      margin: 0;
      padding: 0;
    }
    .custom-container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 24px;
    }
    .form-box {
      background-color: #1c2541 !important; /* Abu-abu gelap */
      border: 1px solid #1e293b !important;
      padding: 24px;
      border-radius: 16px;
      margin-bottom: 40px;
    }
    .card-news {
      background-color: #1c2541 !important;
      border: 1px solid #1e293b !important;
      border-radius: 16px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    .input-field {
      background-color: #0b1329 !important;
      color: #ffffff !important;
      border: 1px solid #334155 !important;
      width: 100%;
      padding: 10px;
      border-radius: 10px;
      box-sizing: border-box;
      outline: none;
    }
    .input-field:focus {
      border-color: #3b82f6 !important;
    }
    .grid-2 {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
    }
    .btn-submit {
      background-color: #2563eb !important;
      color: white !important;
      font-weight: bold;
      padding: 12px 24px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
    }
    .btn-submit:hover {
      background-color: #1d4ed8 !important;
    }
    .btn-delete {
      color: #f43f5e !important;
      background: none;
      border: none;
      font-weight: bold;
      cursor: pointer;
      padding: 0;
    }
    .btn-delete:hover {
      text-decoration: underline;
    }
    .alert-box {
      padding: 16px;
      border-radius: 12px;
      margin-bottom: 24px;
      font-weight: bold;
    }
  </style>
</head>
<body>

  <div class="custom-container">
    
    <!-- HEADER PORTAL ADMIN -->
    <header style="border-b: 1px solid #1e293b; padding-bottom: 20px; margin-bottom: 40px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
      <div>
        <h1 style="font-size: 36px; font-weight: 900; color: #3b82f6; margin: 0;">Panel Admin Nusa Media</h1>
        <p style="color: #94a3b8; margin-top: 8px; font-size: 16px;">Sistem Redaksi Mandiri & Arus Berita Real-Time Supabase.</p>
      </div>
      <a href="/" style="background-color: #2563eb; color: white; text-decoration: none; padding: 10px 20px; border-radius: 10px; font-weight: bold; font-size: 14px;">
        🌐 Ke Halaman Utama
      </a>
    </header>

    <!-- NOTIFIKASI STATUS OPERASI DATABASE -->
    {pesanSukses && <div class="alert-box" style="background-color: #064e3b; color: #34d399; border: 1px solid #059669;">{pesanSukses}</div>}
    {pesanGagal && <div class="alert-box" style="background-color: #4c0519; color: #f43f5e; border: 1px solid #e11d48;">{pesanGagal}</div>}

    <!-- FORMULIR INPUT BERITA MANUAL SUPER LENGKAP -->
    <section class="form-box">
      <h2 style="font-size: 20px; font-weight: bold; color: white; margin-top: 0; margin-bottom: 20px; border-bottom: 1px solid #334155; padding-bottom: 10px;">
        📝 Form Redaksi Berita Super Lengkap
      </h2>
      
      <form method="POST">
        <input type="hidden" name="aksi" value="tambah" />
        
        <div class="grid-2" style="margin-bottom: 20px;">
          <div>
            <label style="display:block; font-size: 12px; font-weight: bold; color: #94a3b8; margin-bottom: 6px; text-transform: uppercase;">Kategori Berita</label>
            <select name="kategori" required class="input-field">
              <option value="Nasional">🇮🇩 Nasional</option>
              <option value="Internasional">🌐 Internasional</option>
              <option value="Ekonomi">💰 Ekonomi</option>
              <option value="Teknologi">💻 Teknologi</option>
              <option value="Olahraga">⚽ Olahraga</option>
              <option value="Hiburan">🎬 Hiburan</option>
            </select>
          </div>

          <div>
            <label style="display:block; font-size: 12px; font-weight: bold; color: #94a3b8; margin-bottom: 6px; text-transform: uppercase;">Nama Penulis / Jurnalis</label>
            <input type="text" name="penulis" required class="input-field" placeholder="Nama lengkap..." />
          </div>
        </div>

        <div class="grid-2" style="margin-bottom: 20px;">
          <div>
            <label style="display:block; font-size: 12px; font-weight: bold; color: #94a3b8; margin-bottom: 6px; text-transform: uppercase;">Tanggal Input Artikel</label>
            <input type="date" name="tanggal_input" class="input-field" />
          </div>

          <div>
            <label style="display:block; font-size: 12px; font-weight: bold; color: #94a3b8; margin-bottom: 6px; text-transform: uppercase;">Slug URL Bersih (Tanpa Spasi)</label>
            <input type="text" name="slug" required class="input-field" placeholder="contoh-slug-berita-baru" />
          </div>
        </div>

        <div class="grid-2" style="margin-bottom: 20px;">
          <div>
            <label style="display:block; font-size: 12px; font-weight: bold; color: #94a3b8; margin-bottom: 6px; text-transform: uppercase;">Judul Utama Berita</label>
            <input type="text" name="judul" required class="input-field" placeholder="Ketik judul berita menarik..." />
          </div>
          <div>
            <label style="display:block; font-size: 12px; font-weight: bold; color: #94a3b8; margin-bottom: 6px; text-transform: uppercase;">URL Link Gambar Sampul</label>
            <input type="url" name="gambar_url" class="input-field" placeholder="https://unsplash.com..." />
          </div>
        </div>

        <div class="grid-2" style="margin-bottom: 20px;">
          <div>
            <label style="display:block; font-size: 12px; font-weight: bold; color: #94a3b8; margin-bottom: 6px; text-transform: uppercase;">URL Embed Video YouTube (Opsional)</label>
            <input type="url" name="youtube_url" class="input-field" placeholder="https://youtube.com..." />
          </div>
          <div>
            <label style="display:block; font-size: 12px; font-weight: bold; color: #94a3b8; margin-bottom: 6px; text-transform: uppercase;">Ringkasan Pendek (Lead Berita)</label>
            <input type="text" name="ringkasan_pendek" required class="input-field" placeholder="Satu kalimat pokok berita..." />
          </div>
        </div>

        <div style="margin-bottom: 20px;">
          <label style="display:block; font-size: 12px; font-weight: bold; color: #94a3b8; margin-bottom: 6px; text-transform: uppercase;">Isi Lengkap Artikel Berita</label>
          <textarea name="isi_artikel" rows="4" required class="input-field" style="resize: none;" placeholder="Tulis narasi berita lengkap di sini secara mendalam..."></textarea>
        </div>

        <div style="display: flex; justify-content: flex-end;">
          <button type="submit" class="btn-submit">
            🚀 Terbitkan Berita Sekarang
          </button>
        </div>
      </form>
    </section>

    <!-- DAFTAR BERITA LIVE + TOMBOL HAPUS -->
    <h2 style="font-size: 24px; font-weight: 900; color: white; margin-bottom: 24px;">
      📰 Aliran Berita Utama (Live Feed)
    </h2>
    
    <div class="grid-2">
      {artikel && artikel.map((item) => (
        <div class="card-news">
          <div>
            {/* Gambar Sampul Berita */}
            {item.gambar_url ? (
              <img src={item.gambar_url} alt={item.judul} style="height: 180px; object-fit: cover; width: 100%; border-top-left-radius:15px; border-top-right-radius:15px;" />
            ) : (
              <div style="height: 180px; background-color: #0b1329; display: flex; align-items: center; justify-content: center; color: #475569; font-size: 12px;">🖼️ Tidak ada gambar sampul</div>
            )}

            <div style="padding: 20px;">
              {/* Label Kategori & Tanggal */}
              <div style="display: flex; justify-content: space-between; align-items: center; font-size: 12px; margin-bottom: 12px;">
                <span style="padding: 4px 10px; background-color: #1e3a8a; color: #93c5fd; border-radius: 6px; font-weight: bold; text-transform: uppercase;">
                  {item.kategori || 'Umum'}
                </span>
                <span style="color: #64748b;">
                  📆 {item.created_at ? new Date(item.created_at).toLocaleDateString('id-ID', {day: 'numeric', month: 'short', year: 'numeric'}) : 'Baru'}
                </span>
              </div>

              {/* Judul & Penulis */}
              <h3 style="font-size: 20px; font-weight: 900; color: white; margin: 0; line-height: 1.3;">
                {item.judul}
              </h3>
              <p style="font-size: 12px; color: #64748b; margin-top: 6px; font-weight: bold;">✍️ Jurnalis: <span style="color: #94a3b8;">{item.penulis || 'Redaksi'}</span></p>

              {/* Ringkasan & Isi Pendek */}
              <div style="background-color: #0b1329; padding: 12px; border-radius: 12px; margin-top: 12px; border: 1px solid #1e293b;">
                <span style="color: #64748b; font-size: 10px; font-weight: bold; display: block; text-transform: uppercase; margin-bottom: 4px;">Ringkasan:</span>
                <p style="font-size: 14px; color: #cbd5e1; margin: 0; line-height: 1.5;">{item.ringkasan}</p>
              </div>

              {/* Tautan YouTube Video */}
              {item.youtube_url && (
                <div style="margin-top: 12px;">
                  <a href={item.youtube_url} target="_blank" rel="noopener noreferrer" style="font-size: 12px; color: #f43f5e; text-decoration: none; font-weight: bold; background-color: #4c0519; padding: 4px 8px; border-radius: 6px;">
                    📺 Tonton Video Terkait
                  </a>
                </div>
              )}
            </div>
          </div>

          <!-- PANEL AKSI BAWAH KARTU -->
          <div style="padding: 20px; border-top: 1px solid #1e293b; display: flex; justify-content: space-between; align-items: center;">
            <!-- Navigasi ke halaman edit root -->
            <a href={`/${item.id}`} style="font-size: 14px; color: #fbbf24; text-decoration: none; font-weight: bold;">
              ✏️ Sunting Teks
            </a>

            <!-- FORMULIR HAPUS INSTAN -->
            <form method="POST" onsubmit="return confirm('Apakah Anda yakin ingin membuang berita ini secara permanen dari database Supabase?');">
              <input type="hidden" name="aksi" value="hapus" />
              <input type="hidden" name="id" value={item.id} />
              <button type="submit" class="btn-delete">
                ❌ Hapus Berita
              </button>
            </form>
          </div>

        </div>
      ))}

      {artikel && artikel.length === 0 && (
        <div style="padding: 60px 20px; background-color: #1c2541; border-radius: 16px; border: 1px dashed #334155; grid-column: span 2; text-align: center;">
          <p style="color: #94a3b8; font-size: 18px; margin: 0; font-weight: bold;">📭 Arus Berita Masih Kosong</p>
          <p style="color: #64748b; font-size: 14px; margin-top: 6px;">Silakan ketik data lengkap di formulir atas untuk menerbitkan artikel pertama Anda.</p>
        </div>
      )}
    </div>

  </div>

  <footer style="background-color: #090d16; border-top: 1px solid #1e293b; color: #475569; font-size: 14px; margin-top: auto; text-align: center; padding: 20px;">
    <p>&copy; 2026 Portal Berita Terpadu Nusa Media. Powered by Astro & Supabase.</p>
  </footer>

</body>
</html>
