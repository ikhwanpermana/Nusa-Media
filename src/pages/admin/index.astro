---
// Kosongkan bagian Node.js atas agar terhindar dari kendala port dan runtime lokal
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard - Nusa Media</title>
</head>
<body style="background-color: #111827; color: #f3f4f6; font-family: sans-serif; padding: 24px;">

  <div style="max-w: 768px; margin: 24px auto; background-color: #1f2937; padding: 32px; border-radius: 16px; border: 1px solid #374151;">
    <header style="margin-bottom: 24px; border-bottom: 1px solid #374151; padding-bottom: 16px; display: flex; justify-content: space-between; align-items: center;">
      <div>
        <h1 style="font-size: 28px; font-weight: 900; color: #60a5fa; margin: 0;">NUSA MEDIA</h1>
        <p style="font-size: 12px; color: #9ca3af; margin: 4px 0 0 0;">v1.0.0 - Mode Hibrida (Manual & Otomatis)</p>
      </div>
    </header>

    <div id="status-box" style="display: none; padding: 16px; margin-bottom: 24px; border-radius: 12px; font-size: 14px;"></div>

    <form id="form-manual" style="display: flex; flex-direction: column; gap: 20px;">
      <div>
        <label style="display: block; font-size: 14px; font-weight: bold; color: #d1d5db; margin-bottom: 8px;">Judul Berita (Manual)</label>
        <input type="text" id="judul" required placeholder="Ketik judul berita manual..." style="width: 100%; padding: 10px; background-color: #4b5563; border: 1px solid #4b5563; border-radius: 12px; color: white; box-sizing: border-box;" />
      </div>
      <div>
        <label style="display: block; font-size: 14px; font-weight: bold; color: #d1d5db; margin-bottom: 8px;">Ringkasan Pendek</label>
        <input type="text" id="ringkasan" required placeholder="Ketik ringkasan berita..." style="width: 100%; padding: 10px; background-color: #4b5563; border: 1px solid #4b5563; border-radius: 12px; color: white; box-sizing: border-box;" />
      </div>
      <button type="submit" style="width: 100%; background-color: #3b82f6; color: white; font-weight: bold; padding: 14px; border-radius: 12px; border: none; cursor: pointer; font-size: 16px;">
        🚀 Terbitkan Berita Manual Sekarang
      </button>
    </form>
  </div>

  <script is:inline>
    // Alamat REST API Supabase murni langsung ke endpoint database
    const API_URL = "https://supabase.co";
    const ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inptdmx2enNwam9ocmV3amJ0ZnhjIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3OTAxMzQxMCwiZXhwIjoyMDk0NTg5NDEwfQ.QVGEGTRkUX90Eg7ct0vb9r2UNtVp0E-gD1XIowDP2S8"; // <-- Tempelkan token ey... Anda di sini

    const form = document.getElementById('form-manual');
    const statusBox = document.getElementById('status-box');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const judul = document.getElementById('judul').value;
      const ringkasan = document.getElementById('ringkasan').value;
      const slug = judul.toLowerCase().replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-');

      try {
        // Menggunakan metode FETCH HTTP standar bawaan semua web browser
        const response = await fetch(API_URL, {
          method: 'POST',
          headers: {
            'apikey': ANON_KEY,
            'Authorization': `Bearer ${ANON_KEY}`,
            'Content-Type': 'application/json',
            'Prefer': 'return=minimal'
          },
          body: JSON.stringify({ judul, ringkasan, slug })
        });

        if (!response.ok) throw new Error(`Eror Server: ${response.statusText}`);

        statusBox.style.display = 'block';
        statusBox.style.backgroundColor = 'rgba(6, 78, 59, 0.5)';
        statusBox.style.color = '#a7f3d0';
        statusBox.innerText = `🟢 Sukses! Berita manual "${judul}" berhasil ditayangkan!`;
        form.reset();
      } catch (err) {
        statusBox.style.display = 'block';
        statusBox.style.backgroundColor = 'rgba(127, 29, 29, 0.5)';
        statusBox.style.color = '#fca5a5';
        statusBox.innerText = `🔴 Gagal: ${err.message}`;
      }
    });
  </script>
</body>
</html>
