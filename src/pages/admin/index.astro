---
// NUSA MEDIA - Premium Admin Dashboard Portal
const judulHalaman = "Nusa Media - Central Control Panel";
const tanggal = "Minggu, 17 Mei 2026";
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{judulHalaman}</title>
    <script src="https://tailwindcss.com"></script>
    <!-- Memanggil Google Fonts untuk tampilan teks premium -->
    <link href="https://googleapis.com" rel="stylesheet">
    <style>body { font-family: 'Plus Jakarta Sans', sans-serif; }</style>
  </head>
  <body class="bg-[#0A0A0A] text-[#E5E5E5] antialiased">

    <!-- LAYOUT UTAMA: SIDEBAR & KONTEN -->
    <div class="min-h-screen flex flex-col md:flex-row">
      
      <!-- MENU SISI KIRI (SIDEBAR ELIT) -->
      <aside class="w-full md:w-64 bg-[#111111] border-b md:border-b-0 md:border-r border-[#222222] p-6 flex flex-col justify-between">
        <div>
          <div class="flex items-center gap-3 pb-6 border-b border-[#222222]">
            <div class="w-8 h-8 rounded bg-white flex items-center justify-center text-black font-black text-sm">N</div>
            <div>
              <h2 class="text-sm font-bold text-white tracking-wider">NUSA MEDIA</h2>
              <p class="text-[10px] text-gray-500 font-mono">v1.0.0 - Cloud Mode</p>
            </div>
          </div>
          
          <!-- DAFTAR MENU NAVIGASI -->
          <nav class="mt-8 space-y-2">
            <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-zinc-900 text-white text-xs font-semibold tracking-wide border border-zinc-800">
              📝 Tulis Berita Baru
            </a>
            <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-zinc-900 hover:text-white text-xs font-semibold tracking-wide transition-all">
              📢 Kelola Slot Iklan
            </a>
            <a href="/" target="_blank" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-zinc-900 hover:text-white text-xs font-semibold tracking-wide transition-all">
              🌐 Lihat Website Utama ↗
            </a>
          </nav>
        </div>

        <div class="pt-6 border-t border-[#222222] text-[10px] text-gray-600 font-mono hidden md:block">
          Logged as <span class="text-gray-400">Super Admin</span>
        </div>
      </aside>

      <!-- KONTEN UTAMA (FORMULIR INPUT MODERN) -->
      <main class="flex-1 p-6 md:p-10 max-w-4xl">
        <!-- HEADER KONTEN -->
        <header class="mb-8 flex flex-col sm:flex-row justify-between sm:items-center gap-2">
          <div>
            <h1 class="text-2xl font-extrabold text-white tracking-tight">Tulis Berita Baru</h1>
            <p class="text-xs text-gray-500 mt-1">Publikasikan informasi digital secara instan dari satu tempat tanpa coding.</p>
          </div>
          <div class="text-right">
            <p class="text-xs font-mono text-zinc-500 bg-zinc-900 px-3 py-1.5 rounded border border-zinc-800 inline-block">{tanggal}</p>
          </div>
        </header>

        <!-- FORMULIR INPUT JURNALISME -->
        <div class="bg-[#111111] border border-[#222222] rounded-xl p-6 md:p-8 shadow-xl">
          <form id="formBerita" class="space-y-6">
            
            <!-- BARIS 1: JUDUL UTAMA -->
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Judul Berita</label>
              <input type="text" name="judul" required placeholder="Masukkan judul berita yang menarik dan fyp..." 
                class="w-full bg-[#161616] border border-[#2A2A2A] rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-white transition-colors" />
            </div>

            <!-- BARIS 2: KATEGORI & SLUG (2 KOLOM) -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Kategori</label>
                <select name="kategori" class="w-full bg-[#161616] border border-[#2A2A2A] rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-white transition-colors">
                  <option value="TEKNOLOGI">TEKNOLOGI</option>
                  <option value="POLITIK">POLITIK & EKONOMI</option>
                  <option value="BISNIS">BISNIS & CUAN</option>
                  <option value="GAYA HIDUP">GAYA HIDUP</option>
                  <option value="TREN UTAMA">TREN UTAMA (FYP)</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Penulis / Jurnalis</label>
                <input type="text" name="penulis" value="Redaksi Nusa Media" placeholder="Nama jurnalis..." 
                  class="w-full bg-[#161616] border border-[#2A2A2A] rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-white transition-colors" />
              </div>
            </div>

            <!-- BARIS 3: RINGKASAN PENDEK -->
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Ringkasan Pendek (Halaman Depan)</label>
              <input type="text" name="ringkasan" required placeholder="Tulis 1 kalimat ringkasan pendek untuk memancing klik pembaca..." 
                class="w-full bg-[#161616] border border-[#2A2A2A] rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-white transition-colors" />
            </div>

            <!-- BARIS 4: ARTIKEL UTUH LENGKAP -->
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Isi Artikel Utama (Utuh)</label>
              <textarea name="isi_berita" rows="8" required placeholder="Ketik isi narasi berita lengkap Anda secara mendalam di sini..." 
                class="w-full bg-[#161616] border border-[#2A2A2A] rounded-lg p-4 text-sm text-white focus:outline-none focus:border-white transition-colors leading-relaxed"></textarea>
            </div>

            <!-- BARIS 5: URL GAMBAR ILUSTRASI -->
            <div>
              <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">URL Gambar Sampul (Link Foto)</label>
              <input type="url" name="url_gambar" placeholder="https://unsplash.com..." 
                class="w-full bg-[#161616] border border-[#2A2A2A] rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-white transition-colors text-xs font-mono" />
            </div>

            <!-- TOMBOL SUBMIT MEWAH -->
            <div class="pt-4">
              <button type="submit" class="w-full md:w-auto bg-white text-black hover:bg-gray-200 transition-all font-bold text-xs uppercase tracking-widest px-8 py-4 rounded-lg shadow-lg">
                🚀 Terbitkan Berita Sekarang
              </button>
            </div>

          </form>
        </div>
      </main>

    </div>

    <!-- SISTEM KONEKSI AJARAN ROBOT KE SUPABASE (TANPA RELOAD PAGE) -->
    <script>
      const form = document.getElementById('formBerita');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Mengambil data ketikan Anda dari formulir
        const formData = new FormData(form);
        const dataBerita = {
          kategori: formData.get('kategori'),
          judul: formData.get('judul'),
          ringkasan: formData.get('ringkasan'),
          isi_berita: formData.get('isi_berita'),
          penulis: formData.get('penulis'),
          sumber: 'Nusa Media Redaksi',
          url_sumber: window.location.origin,
          url_gambar: formData.get('url_gambar') || 'https://unsplash.com1504711434969-e33886168f5c'
        };

        // Alamat tembak langsung ke REST API Supabase Anda (Sangat Cepat & Ringan)
        const SUPABASE_URL = "https://supabase.co";
        
        try {
          const response = await fetch(SUPABASE_URL, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Prefer': 'return=minimal'
            },
            body: JSON.stringify(dataBerita)
          });

          if(response.ok) {
            alert('🎉 Sukses! Berita baru Anda berhasil diterbitkan secara live ke seluruh dunia.');
            form.reset();
          } else {
            alert('Gagal menerbitkan berita. Sila pastikan kredensial atau tabel database Anda sudah sesuai.');
          }
        } catch (error) {
          alert('Terjadi kesalahan jaringan: ' + error.message);
        }
      });
    </script>

  </body>
</html>
