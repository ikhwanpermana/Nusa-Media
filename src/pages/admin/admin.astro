---
import { supabase } from '../lib/supabase';
export const prerender = false;

// Mengambil data artikel secara live dari database Supabase untuk publik
const { data: artikel, error } = await supabase
  .from('posts')
  .select('*')
  .order('id', { ascending: false });

// Memisahkan berita utama pertama (Hero) dan sisa berita lainnya
const beritaUtama = artikel && artikel.length > 0 ? artikel[0] : null;
const beritaSisa = artikel && artikel.length > 1 ? artikel.slice(1) : [];
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nusa Media - Portal Berita Dunia Terkini</title>

  <!-- KODE CSS GLOBAL: Standar Desain Media Internasional (Bersih & Tipografi Kuat) -->
  <style is:global>
    @import url('https://googleapis.com');
    
    body {
      background-color: #fdfdfd !important;
      color: #0f172a !important;
      font-family: 'Plus Jakarta Sans', sans-serif;
      margin: 0;
      padding: 0;
    }
    .serif-title {
      font-family: 'Playfair Display', serif;
    }
    .main-layout {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .nav-bar {
      border-bottom: 2px solid #0f172a;
      padding: 20px 0;
      margin-bottom: 32px;
      text-align: center;
    }
    .hero-section {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 32px;
      border-bottom: 1px solid #e2e8f0;
      padding-bottom: 40px;
      margin-bottom: 40px;
    }
    @media (max-width: 768px) {
      .hero-section {
        grid-template-columns: 1fr;
      }
    }
    .news-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 32px;
      margin-bottom: 60px;
    }
    .img-wrapper {
      position: relative;
      overflow: hidden;
      border-radius: 8px;
      background-color: #f1f5f9;
    }
    .img-fluid {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
    .img-wrapper:hover .img-fluid {
      transform: scale(1.03);
    }
    .tag-category {
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #2563eb;
      margin-bottom: 8px;
      display: inline-block;
    }
    .read-more-link {
      color: #0f172a;
      text-decoration: none;
      font-weight: 700;
      font-size: 14px;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin-top: 12px;
    }
    .read-more-link:hover {
      color: #2563eb;
    }
  </style>
</head>
<body>

  <!-- 1. HEADER UTAMA (Gaya Koran Kelas Dunia / New York Times Style) -->
  <div class="main-layout">
    <div class="nav-bar">
      <div style="font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: #64748b; margin-bottom: 4px;">
        {new Date().toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
      </div>
      <h1 class="serif-title" style="font-size: 52px; font-weight: 700; margin: 0; tracking-tight: -0.05em;">NUSA MEDIA</h1>
      <div style="border-top: 1px solid #e2e8f0; margin-top: 16px; padding-top: 8px; font-size: 13px; font-weight: 600; color: #475569; display: flex; justify-content: center; gap: 24px;">
        <span>INDONESIA</span> &bull; <span>DUNIA</span> &bull; <span>EKONOMI</span> &bull; <span>TEKNOLOGI</span> &bull; <span>GAYA HIDUP</span>
      </div>
    </div>

    <!-- TAMPILAN JIKA TERJADI KENDALA KONEKSI -->
    {error && (
      <div style="padding: 16px; background-color: #fef2f2; border: 1px solid #fca5a5; color: #991b1b; border-radius: 8px; margin-bottom: 24px; font-size: 14px; text-align: center;">
        Layanan sedang memuat ulang arsip berita secara berkala.
      </div>
    )}

    <!-- 2. BERITA UTAMA / HERO SECTION (Jika data tersedia) -->
    {beritaUtama && (
      <section class="hero-section">
        <!-- Sisi Kiri: Gambar Besar & Judul Utama -->
        <div style="display: flex; flex-direction: column; gap: 16px;">
          <div class="img-wrapper" style="height: 450px;">
            {beritaUtama.gambar_url ? (
              <img src={beritaUtama.gambar_url} alt={beritaUtama.judul} class="img-fluid" />
            ) : (
              <div style="height: 100%; display: flex; align-items: center; justify-content: center; color: #94a3b8;">Nusa Media Photo Archive</div>
            )}
          </div>
          <div>
            <span class="tag-category">{beritaUtama.kategori || 'Fokus Utama'}</span>
            <h2 class="serif-title" style="font-size: 36px; font-weight: 700; margin: 4px 0 12px 0; line-height: 1.15; cursor: pointer;">
              {beritaUtama.judul}
            </h2>
            <p style="font-size: 16px; color: #334155; line-height: 1.6; margin: 0;">
              {beritaUtama.ringkasan}
            </p>
            <div style="margin-top: 12px; font-size: 13px; color: #64748b; font-weight: 600;">
              Oleh <span style="color: #0f172a;">{beritaUtama.penulis || 'Redaksi'}</span> &bull; {beritaUtama.created_at ? new Date(beritaUtama.created_at).toLocaleDateString('id-ID', {month: 'short', day: 'numeric'}) : ''}
            </div>
          </div>
        </div>

        <!-- Sisi Kanan: Pengantar Editorial Singkat Kelas Dunia -->
        <div style="border-left: 1px solid #e2e8f0; padding-left: 32px; display: flex; flex-direction: column; justify-content: space-between;" class="hidden-mobile">
          <div style="border-bottom: 3px solid #0f172a; padding-bottom: 8px; margin-bottom: 16px;">
            <h4 style="margin: 0; font-size: 14px; font-weight: 800; uppercase; tracking: 1px;">SOROTAN HARI INI</h4>
          </div>
          <div style="flex-grow: 1; display: flex; flex-direction: column; gap: 20px;">
            <p style="font-size: 15px; font-style: italic; line-height: 1.6; color: #475569; margin: 0;">
              "Menyajikan arus jurnalisme bermutu tinggi, berimbang, dan independen langsung dari penjuru nusantara dan dunia."
            </p>
            {beritaUtama.youtube_url && (
              <a href={beritaUtama.youtube_url} target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; font-size: 13px; color: #e11d48; text-decoration: none; font-weight: 700; bg-color:#fff1f2; padding: 10px; border-radius: 6px; border:1px solid #ffe4e6; text-align:center;">
                📺 Buka Liputan Video Terkait
              </a>
            )}
          </div>
          <div style="background-color: #f8fafc; padding: 16px; border-radius: 8px; border: 1px solid #e2e8f0; margin-top: 20px;">
            <span style="font-size: 11px; font-weight: 800; color: #64748b; display: block; margin-bottom: 4px;">EDISI DIGITAL</span>
            <span style="font-size: 13px; font-weight: 700; color: #0f172a;">Akses Tanpa Batas 24 Jam Live</span>
          </div>
        </div>
      </section>
    )}

    <!-- 3. KISI BERITA GRID (Untuk sisa berita lainnya) -->
    {beritaSisa.length > 0 && (
      <h3 class="serif-title" style="font-size: 24px; font-weight: 700; margin-bottom: 24px; border-bottom: 1px solid #0f172a; padding-bottom: 8px;">
        Arsip Berita Terbaru
      </h3>
    )}

    <section class="news-grid">
      {beritaSisa.map((item) => (
        <article style="display: flex; flex-direction: column; justify-content: space-between; border-bottom: 1px solid #f1f5f9; padding-bottom: 16px;">
          <div style="display: flex; flex-direction: column; gap: 12px;">
            <div class="img-wrapper" style="height: 200px;">
              {item.gambar_url ? (
                <img src={item.gambar_url} alt={item.judul} class="img-fluid" />
              ) : (
                <div style="height: 100%; display: flex; align-items: center; justify-content: center; color: #cbd5e1; font-size: 12px;">Nusa Media Gallery</div>
              )}
            </div>
            
            <div>
              <span class="tag-category">{item.kategori || 'Umum'}</span>
              <h4 class="serif-title" style="font-size: 19px; font-weight: 700; margin: 4px 0 8px 0; line-height: 1.3; color: #0f172a;">
                {item.judul}
              </h4>
              <p style="font-size: 14px; color: #475569; line-height: 1.5; margin: 0; line-clamp: 3; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                {item.ringkasan}
              </p>
            </div>
          </div>

          <div style="margin-top: 16px; display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: #64748b; font-weight: 600; border-top: 1px dashed #e2e8f0; padding-top: 12px;">
            <span>Oleh {item.penulis || 'Redaksi'}</span>
            <span>📆 {item.created_at ? new Date(item.created_at).toLocaleDateString('id-ID', {month: 'short', day: 'numeric'}) : ''}</span>
          </div>
        </article>
      ))}
    </section>

    {(!artikel || artikel.length === 0) && (
      <div style="text-align: center; padding: 80px 24px; color: #64748b;">
        <p style="font-size: 18px; font-weight: 700; margin: 0;">Belum Ada Warta Hari Ini</p>
        <p style="font-size: 14px; margin-top: 4px;">Arus berita global sedang dipersiapkan oleh dewan jurnalis.</p>
      </div>
    )}
  </div>

  <!-- 4. FOOTER MEDIA GLOBAL (Bersih & Elegan) -->
  <footer style="background-color: #0f172a; color: #94a3b8; padding: 40px 0; margin-top: auto; font-size: 14px;">
    <div class="main-layout" style="display: flex; flex-col sm:flex-row; justify-content: space-between; align-items: center; gap: 16px;">
      <div>
        <strong style="color: white; font-size: 16px; font-family: 'Playfair Display', serif; tracking-wider: 1px;">NUSA MEDIA</strong>
        <p style="margin: 6px 0 0 0; font-size: 12px; color: #475569;">&copy; 2026 PT Nusa Media Internasional. Hak Cipta Dilindungi.</p>
      </div>
      
      <!-- Pintu Akses Tersembunyi (Hanya berupa link teks kecil abu-abu di pojok kanan bawah agar tidak merusak tampilan umum) -->
      <a href="/admin" style="color: #334155; text-decoration: none; font-size: 11px; font-weight: 700; border: 1px solid #1e293b; padding: 4px 8px; border-radius: 4px; transition: color 0.3s;" onmouseover="this.style.color='#64748b'" onmouseout="this.style.color='#334155'">
        GATEWAY LOGIN
      </a>
    </div>
  </footer>

</body>
</html>
