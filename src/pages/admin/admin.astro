---
// 1. KODE SERVER ASTRO: Cek koneksi & ambil data admin
import { supabase } from '../lib/supabase';

// Mengambil data artikel sekaligus menguji koneksi database
const { data: artikel, error } = await supabase
  .from('posts')
  .select('id, judul, created_at')
  .order('created_at', { ascending: false });

// Logika penentu status koneksi database
const isConnected = !error && artikel !== null;
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel Admin - Nusa Media</title>
  </head>
  <body class="bg-gray-100 text-gray-900 font-sans antialiased">

    <div class="flex min-h-screen">
      <!-- Sidebar Admin -->
      <aside class="w-64 bg-slate-900 text-white p-6 hidden md:block">
        <h2 class="text-xl font-black tracking-wider text-amber-500 mb-8">NUSA ADMIN</h2>
        <nav class="space-y-2">
          <a href="/admin" class="block py-2.5 px-4 rounded bg-slate-800 text-amber-400 font-semibold">
            Dashboard
          </a>
          <a href="/" class="block py-2.5 px-4 rounded hover:bg-slate-800 text-slate-300 transition-colors">
            Lihat Website →
          </a>
        </nav>
      </aside>

      <!-- Konten Utama Admin -->
      <main class="flex-1 p-6 md:p-10">
        
        <!-- Baris Judul & Indikator Status Koneksi -->
        <header class="flex flex-col md:flex-row md:items-center md:justify-between pb-6 border-b border-gray-200 mb-8 gap-4">
          <div>
            <h1 class="text-3xl font-bold tracking-tight text-slate-800">Dashboard Manajemen Berita</h1>
            <p class="text-gray-500 text-sm mt-1">Kelola konten portal Berita Nusa Media Anda.</p>
          </div>
          
          <!-- INDIKATOR UTAMA KONEKSI DATABASE -->
          <div class="flex items-center gap-2">
            {isConnected ? (
              <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-green-100 text-green-800 border border-green-200">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                Database Terhubung
              </span>
            ) : (
              <span class="inline-flex items-center gap-1.5 py-1.5 px-3 rounded-full text-xs font-medium bg-red-100 text-red-800 border border-red-200">
                <span class="w-2 h-2 rounded-full bg-red-500"></span>
                Koneksi Terputus
              </span>
            )}
          </div>
        </header>

        <!-- Jika Terjadi Error / Gagal Hubung -->
        {error && (
          <div class="p-4 mb-6 text-red-800 bg-red-50 border border-red-200 rounded-xl text-sm">
            <h3 class="font-bold mb-1">Gagal Sinkronisasi dengan Supabase:</h3>
            <p class="font-mono text-xs text-red-600 bg-white p-2 rounded border mt-2">{error.message}</p>
          </div>
        )}

        <!-- Statistik Singkat -->
        <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <div class="p-6 bg-white rounded-xl shadow-sm border border-gray-200">
            <p class="text-sm font-medium text-gray-500 truncate">Total Artikel Saat Ini</p>
            <p class="mt-2 text-3xl font-semibold text-slate-900">{artikel ? artikel.length : 0}</p>
          </div>
        </section>

        <!-- Tabel Daftar Berita dari Database -->
        <section class="bg-white shadow-sm rounded-xl border border-gray-200 overflow-hidden">
          <div class="p-5 border-b border-gray-100">
            <h3 class="font-bold text-slate-800">Daftar Posting</h3>
          </div>
          
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-slate-50 border-b border-gray-200 text-xs font-semibold text-gray-600 uppercase tracking-wider">
                  <th class="p-4">ID</th>
                  <th class="p-4">Judul Berita</th>
                  <th class="p-4">Tanggal Dibuat</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 text-sm text-gray-700">
                {artikel && artikel.map((post) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="p-4 font-mono text-gray-400">{post.id}</td>
                    <td class="p-4 font-semibold text-slate-900">{post.judul}</td>
                    <td class="p-4 text-gray-500">{new Date(post.created_at).toLocaleDateString('id-ID')}</td>
                  </tr>
                ))}

                {(!artikel || artikel.length === 0) && (
                  <tr>
                    <td colspan="3" class="p-8 text-center text-gray-400">
                      Tidak ada data posting yang ditemukan di database.
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </section>

      </main>
    </div>

  </body>
</html>
