---
import { supabase } from '../lib/supabase';
export const prerender = false;

// Mengambil data artikel secara live dari database Supabase untuk publik
const { data: artikel, error } = await supabase
  .from('posts')
  .select('*')
  .order('id', { ascending: false });

// Memisahkan berita utama pertama (Hero Story) dan sisa berita lainnya (Grid)
const beritaUtama = artikel && artikel.length > 0 ? artikel[0] : null;
const beritaSisa = artikel && artikel.length > 1 ? artikel.slice(1) : [];
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nusa Media - Portal Berita Dunia Terkini</title>

  <!-- TIPOGRAFI PREMIUM: Menggabungkan Playfair Display (Serif) & Plus Jakarta Sans (Sans-Serif) -->
  <style is:global>
    @import url('https://googleapis.com');
    
    body {
      background-color: #fdfdfd !important;
      color: #0f172a !important;
      font-family: 'Plus Jakarta Sans', sans-serif;
      margin: 0;
      padding: 0;
    }
    .serif-title {
      font-family: 'Playfair Display', serif;
    }
    .main-layout {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .nav-bar {
      border-bottom: 2px solid #0f172a;
      padding: 24px 0;
      margin-bottom: 32px;
      text-align: center;
    }
    .hero-section {
      display: grid;
      grid-template-columns: 2.2fr 1fr;
      gap: 40px;
      border-bottom: 1px solid #e2e8f0;
      padding-bottom: 40px;
      margin-bottom: 40px;
    }
    @media (max-width: 768px) {
      .hero-section {
        grid-template-columns: 1fr;
        gap: 24px;
      }
    }
    .news-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 40px;
      margin-bottom: 60px;
    }
    .img-wrapper {
      position: relative;
      overflow: hidden;
      border-radius: 6px;
      background-color: #f1f5f9;
    }
    .img-fluid {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .img-wrapper:hover .img-fluid {
      transform: scale(1.02);
    }
    .tag-category {
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #1d4ed8;
      margin-bottom: 10px;
      display: inline-block;
    }
    .lead-text {
      font-size: 16px;
      color: #334155;
      line-height: 1.65;
    }
    .meta-text {
      font-size: 13px;
      color: #64748b;
      font-weight: 600;
    }
  </style>
</head>
<body>

  <div class="main-layout">
    
    <!-- 1. HEADER UTAMA (Gaya Koran Kelas Dunia / Editorial Tradisional) -->
    <header class="nav-bar">
      <div style="font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 3px; color: #64748b; margin-bottom: 6px;">
        {new Date().toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
      </div>
      <h1 class="serif-title" style="font-size: 56px; font-weight: 900; margin: 0; tracking-tight: -0.05em; color: #0f172a;">
        NUSA MEDIA
      </h1>
      <div style="border-top: 1px solid #e2e8f0; margin-top: 18px; padding-top: 10px; font-size: 12px; font-weight: 700; color: #475569; display: flex; justify-content: center; gap: 32px; letter-spacing: 1px;">
        <span>INDONESIA</span> &bull; <span>DUNIA</span> &bull; <span>EKONOMI</span> &bull; <span>TEKNOLOGI</span> &bull; <span>GAYA HIDUP</span>
      </div>
    </header>

    <!-- PENGAMAN ERROR DI LAYAR PUBLIK -->
    {error && (
      <div style="padding: 14px; background-color: #f8fafc; border: 1px solid #e2e8f0; color: #475569; border-radius: 6px; margin-bottom: 32px; font-size: 13px; text-align: center; font-weight: 500;">
        Menyinkronkan ulang arsip berita terkini...
      </div>
    )}

    <!-- 2. HERO SECTION: BERITA PALING BARU SECARA OTOMATIS BERUKURAN BESAR -->
    {beritaUtama && (
      <section class="hero-section">
        <!-- Kolom Kiri Utama: Gambar Raksasa & Konten Inti -->
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <div class="img-wrapper" style="height: 460px;">
            {beritaUtama.gambar_url ? (
              <img src={beritaUtama.gambar_url} alt={beritaUtama.judul} class="img-fluid" />
            ) : (
              <div style="height: 100%; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-weight: 500; font-size: 14px;">Arsip Dokumentasi Nusa Media</div>
            )}
          </div>
          <div>
            <span class="tag-category">{beritaUtama.kategori || 'Fokus Utama'}</span>
            <h2 class="serif-title" style="font-size: 38px; font-weight: 700; margin: 4px 0 14px 0; line-height: 1.15; letter-spacing: -0.02em;">
              {beritaUtama.judul}
            </h2>
            <p class="lead-text" style="margin-bottom: 16px;">
              {beritaUtama.ringkasan}
            </p>
            <div class="meta-text">
              Oleh <span style="color: #0f172a; font-weight: 700;">{beritaUtama.penulis || 'Redaksi'}</span> &bull; {beritaUtama.created_at ? new Date(beritaUtama.created_at).toLocaleDateString('id-ID', {month: 'short', day: 'numeric', year: 'numeric'}) : ''}
            </div>
          </div>
        </div>

        <!-- Kolom Kanan: Catatan Sorotan & Kolom Multimedia Khusus Pembaca -->
        <div style="border-left: 1px solid #e2e8f0; padding-left: 40px; display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <div style="border-bottom: 2px solid #0f172a; padding-bottom: 6px; margin-bottom: 16px;">
              <h4 style="margin: 0; font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; color: #0f172a;">SOROTAN UTAMA</h4>
            </div>
            <p style="font-size: 15px; font-style: italic; line-height: 1.65; color: #475569; margin: 0; font-family: 'Playfair Display', serif;">
              "Menyajikan jurnalisme bermutu tinggi secara independen, lugas, dan terpercaya langsung dari pusat informasi database."
            </p>
          </div>

          {beritaUtama.youtube_url && (
            <div style="margin: 24px 0;">
              <a href={beritaUtama.youtube_url} target="_blank" rel="noopener noreferrer" style="display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 13px; color: #df1b41; text-decoration: none; font-weight: 700; background-color: #fff1f2; padding: 12px; border-radius: 8px; border: 1px solid #ffe4e6; transition: background-color 0.2s;">
                📺 Saksikan Dokumentasi Video
              </a>
            </div>
          )}

          <div style="background-color: #f8fafc; padding: 18px; border-radius: 8px; border: 1px solid #e2e8f0;">
            <span style="font-size: 10px; font-weight: 800; color: #64748b; display: block; margin-bottom: 4px; letter-spacing: 1px; text-transform: uppercase;">EDISI LIVE DIGITAL</span>
            <span style="font-size: 13px; font-weight: 700; color: #0f172a;">Akses Informasi Publik Terbuka 24 Jam</span>
          </div>
        </div>
      </section>
    )}

    <!-- 3. GRID SYSTEM: UNTUK ARSIP BERITA LAMA -->
    {beritaSisa && beritaSisa.length > 0 && (
      <h3 class="serif-title" style="font-size: 24px; font-weight: 700; margin-top: 16px; margin-bottom: 24px; border-bottom: 1px solid #0f172a; padding-bottom: 8px; letter-spacing: -0.01em;">
        Warta Terbaru Lainnya
      </h3>
    )}

    <section class="news-grid">
      {beritaSisa && beritaSisa.map((item) => (
        <article style="display: flex; flex-direction: column; justify-content: space-between; border-bottom: 1px solid #f1f5f9; padding-bottom: 20px;">
          <div style="display: flex; flex-direction: column; gap: 14px;">
            <div class="img-wrapper" style="height: 210px;">
              {item.gambar_url ? (
                <img src={item.gambar_url} alt={item.judul} class="img-fluid" />
              ) : (
                <div style="height: 100%; display: flex; align-items: center; justify-content: center; color: #cbd5e1; font-size: 13px; font-weight: 500;">Dokumentasi Gambar</div>
              )}
            </div>
            
            <div>
              <span class="tag-category">{item.kategori || 'Umum'}</span>
              <h4 class="serif-title" style="font-size: 20px; font-weight: 700; margin: 4px 0 10px 0; line-height: 1.32; color: #0f172a; letter-spacing: -0.01em;">
                {item.judul}
              </h4>
              <p style="font-size: 14.5px; color: #475569; line-height: 1.6; margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                {item.ringkasan}
              </p>
            </div>
          </div>

          <div style="margin-top: 20px; display: flex; justify-content: space-between; align-items: center; font-size: 12.5px; color: #64748b; font-weight: 600; border-top: 1px dashed #e2e8f0; padding-top: 12px;">
            <span>Oleh {item.penulis || 'Redaksi'}</span>
            <span>{item.created_at ? new Date(item.created_at).toLocaleDateString('id-ID', {month: 'short', day: 'numeric'}) : ''}</span>
          </div>
        </article>
      ))}
    </section>

    <!-- TAMPILAN JIKA DATABASE KOSONG TOTAL -->
    {(!artikel || artikel.length === 0) && (
      <div style="text-align: center; padding: 100px 24px; color: #64748b;">
        <p class="serif-title" style="font-size: 22px; font-weight: 700; margin: 0; color: #334155;">Belum Ada Berita yang Diterbitkan</p>
        <p style="font-size: 14px; margin-top: 6px; color: #94a3b8;">Arus warta harian sedang dipersiapkan oleh dewan redaksi jurnalis.</p>
      </div>
    )}
  </div>

  <!-- 4. FOOTER MEDIA GLOBAL + PINTU RAHASIA SAMAR -->
  <footer style="background-color: #0f172a; color: #94a3b8; padding: 48px 0; margin-top: auto; font-size: 14px; border-top: 4px solid #1e293b;">
    <div class="main-layout" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
      <div>
        <strong class="serif-title" style="color: white; font-size: 18px; letter-spacing: 1px;">NUSA MEDIA</strong>
        <p style="margin: 8px 0 0 0; font-size: 12px; color: #475569; font-weight: 500;">&copy; 2026 PT Nusa Media Internasional. Seluruh Hak Cipta Dilindungi.</p>
      </div>
      
      <!-- PINTU RAHASIA: Berwarna sangat samar menyatu dengan latar belakang gelap footer -->
      <a 
        href="/admin" 
        style="color: #1e293b; text-decoration: none; font-size: 10px; font-weight: 800; border: 1px solid #131c2e; padding: 5px 10px; border-radius: 4px; tracking-wider: 1px; transition: all 0.3s;"
        onmouseover="this.style.color='#475569'; this.style.borderColor='#273549'"
        onmouseout="this.style.color='#1e293b'; this.style.borderColor='#131c2e'"
      >
        GATEWAY LOGIN
      </a>
    </div>
  </footer>

</body>
</html>
