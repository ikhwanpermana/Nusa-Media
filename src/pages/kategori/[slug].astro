---
// File: src/pages/kategori/[slug].astro
import { createClient } from '@supabase/supabase-js';

const { slug } = Astro.params;
const supabase = createClient(import.meta.env.SUPABASE_URL, import.meta.env.SUPABASE_ANON_KEY);

// 1. Ambil info kategori berdasarkan slug URL
const { data: kategori } = await supabase
  .from('kategori')
  .select('*')
  .eq('slug', slug)
  .single();

if (!kategori) return Astro.redirect('/404');

// 2. Tarik semua berita yang ada di kategori tersebut
const { data: daftarBerita } = await supabase
  .from('berita')
  .select('*, penulis(nama)')
  .eq('kategori_id', kategori.id)
  .eq('status', 'Terbit')
  .order('created_at', { ascending: false });

const judulSitus = "NUSA MEDIA";
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{kategori.nama} - {judulSitus}</title>
  </head>
  <body class="bg-[#111111] text-[#E5E5E5] font-sans antialiased">
    <header class="border-b border-[#2A2A2A] py-6 text-center">
      <a href="/" class="text-xs uppercase tracking-widest text-gray-500 hover:text-white">&larr; Beranda</a>
      <h1 class="text-4xl font-serif font-black text-white mt-2">KATEGORI: {kategori.nama}</h1>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {daftarBerita && daftarBerita.map((berita) => (
          <div class="border border-[#2A2A2A] bg-[#1A1A1A] p-6 flex flex-col justify-between">
            <div>
              {berita.gambar_url && (
                <img src={berita.gambar_url} alt={berita.judul} class="w-full aspect-video object-cover mb-4 border border-[#2A2A2A]" />
              )}
              <h2 class="text-xl font-bold text-white hover:underline">
                <a href={`/berita/${berita.slug}`}>{berita.judul}</a>
              </h2>
              <p class="text-gray-400 text-sm mt-2 line-clamp-3">{berita.ringkasan}</p>
            </div>
            <span class="text-xs text-gray-500 mt-4">Oleh {berita.penulis?.nama || 'Redaksi'}</span>
          </div>
        ))}
      </div>
    </main>
  </body>
</html>
