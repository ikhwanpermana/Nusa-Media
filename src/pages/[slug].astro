---
// src/pages/berita/[slug].astro
export const prerender = true; // Tetap menggunakan mode statis sesuai arsitektur pilihan Anda

export async function getStaticPaths() {
  const SUPABASE_PROJECT_ID = "zmvlvzspjohrewjbtfxc";
  const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inptdmx2enNwam9ocmV3amJ0ZnhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMTM0MTAsImV4cCI6MjA5NDU4OTQxMH0.PtTVq_b4gLonRpNSbPYKncoXlGVS1lKaADy74dbhuSI";
  
  try {
    const response = await fetch(`https://${SUPABASE_PROJECT_ID}.supabase.co/rest/v1/berita?select=slug`, {
      headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
    });
    const daftarBerita = await response.json();
    
    if (!Array.isArray(daftarBerita)) {
      return [];
    }

    // Menyaring rute khusus admin agar tidak bertubrukan
    return daftarBerita
      .filter((item) => item.slug && item.slug !== 'admin-rahasia-99')
      .map((item) => ({
        params: { slug: item.slug.toString() },
      }));
  } catch (error) {
    return [];
  }
}

const { slug } = Astro.params;
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nusa Media - Detail Berita</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://w3.org viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📰</text></svg>">
    <script src="https://tailwindcss.com"></script>
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Roboto', sans-serif; }
    </style>
  </head>
  <body class="bg-gray-100 text-gray-900 antialiased min-h-screen">
    
    <!-- Tombol Navigasi Kembali -->
    <div class="max-w-3xl mx-auto px-4 pt-10">
      <a href="/" class="text-sm font-bold text-red-600 hover:text-red-700 transition flex items-center gap-1">
        ← Kembali ke Beranda
      </a>
    </div>

    <!-- Wadah Konten Utama Berita -->
    <main class="max-w-3xl mx-auto px-4 py-6 space-y-6">
      
      <!-- SLOT IKLAN ATAS -->
      <div id="wadah-iklan-tengah" class="w-full">
        <div class="w-full bg-white border border-dashed border-gray-300 p-3 text-center text-gray-400 text-xs rounded-xl animate-pulse">
          Memuat Iklan Banner...
        </div>
      </div>

      <article id="kontenArtikel" class="bg-white rounded-xl border border-gray-200 p-6 sm:p-8 shadow-sm space-y-6">
        <!-- Animasi Skeleton Pemuatan Awal -->
        <div class="space-y-4 animate-pulse">
          <div class="h-4 bg-gray-200 rounded w-1/4"></div>
          <div class="h-8 bg-gray-200 rounded w-3/4"></div>
          <div class="h-4 bg-gray-200 rounded w-1/2"></div>
          <div class="h-64 bg-gray-200 rounded-xl w-full"></div>
          <div class="space-y-2">
            <div class="h-4 bg-gray-200 rounded w-full"></div>
            <div class="h-4 bg-gray-200 rounded w-full"></div>
          </div>
        </div>
      </article>

      <!-- SLOT IKLAN BAWAH -->
      <div id="wadah-iklan-bawah" class="w-full"></div>

    </main>

    <!-- KONEKSI CLIENT-SIDE LIVE KE SUPABASE BERDASARKAN SLUG (DIPERBAIKI SECARA PENUH) -->
    <script is:inline define:vars={{ slug }}>
      const container = document.getElementById('kontenArtikel');
      const adTengahContainer = document.getElementById('wadah-iklan-tengah');
      const adBawahContainer = document.getElementById('wadah-iklan-bawah');
      
      const SUPABASE_PROJECT_ID = "zmvlvzspjohrewjbtfxc";
      const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inptdmx2enNwam9ocmV3amJ0ZnhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMTM0MTAsImV4cCI6MjA5NDU4OTQxMH0.PtTVq_b4gLonRpNSbPYKncoXlGVS1lKaADy74dbhuSI";

      async function muatDataDinamis() {
        try {
          // 1. Tarik Data Berita Real-time berdasarkan slug teks
          const resBerita = await fetch(`https://${SUPABASE_PROJECT_ID}.supabase.co/rest/v1/berita?slug=eq.${slug}&select=*`, {
            headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
          });
          const dataBerita = await resBerita.json();
          const berita = dataBerita && dataBerita.length > 0 ? dataBerita[0] : null;

          if (!berita) {
            container.innerHTML = `<div class="text-center py-12"><p class="text-gray-500 font-medium">Berita tidak ditemukan.</p></div>`;
            adTengahContainer.style.display = 'none';
            return;
          }

          // Render Isi Berita Lengkap ke Layar
          const judulArtikel = berita.judul || 'Tanpa Judul';
          const kategoriArtikel = berita.kategori || 'FOKUS';
          const penulisArtikel = berita.penulis || 'Redaksi';
          const kontenArtikel = berita.isi_konten || berita.ringkasan || 'Tidak ada isi konten.';
          const gambarArtikel = berita.gambar_url || "https://unsplash.com";
          const tanggalArtikel = berita.created_at ? new Date(berita.created_at).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) : 'Baru saja';

          container.innerHTML = `
            <div class="space-y-4">
              <span class="bg-red-600 text-white text-[10px] font-bold px-2.5 py-1 rounded uppercase tracking-wider inline-block">${kategoriArtikel}</span>
              <h1 class="text-2xl sm:text-3xl font-black text-gray-900 leading-tight">${judulArtikel}</h1>
              <div class="text-xs text-gray-400 border-b pb-4 flex flex-wrap gap-2 justify-between">
                <span>Penulis: <strong class="text-gray-700">${penulisArtikel}</strong></span>
                <span>📅 ${tanggalArtikel}</span>
              </div>
              <div class="overflow-hidden rounded-xl bg-gray-100">
                <img src="${gambarArtikel}" alt="${judulArtikel}" class="w-full h-auto max-h-[400px] object-cover mx-auto" />
              </div>
              <p class="text-gray-800 text-lg leading-relaxed whitespace-pre-line pt-4 font-serif">${kontenArtikel}</p>
            </div>
          `;

          // 2. Tarik Data Iklan Gambar Secara Terpisah
          const resIklan = await fetch(`https://${SUPABASE_PROJECT_ID}.supabase.co/rest/v1/iklan?status=eq.Aktif&select=*`, {
            headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
          });
          const listIklan = await resIklan.json();

          if (Array.isArray(listIklan) && listIklan.length > 0) {
            // Mengambil iklan acak atau iklan pertama untuk banner
            const iklanAktif = listIklan[0];
            const gambarIklan = iklanAktif.gambar_url || "";
            
            if (gambarIklan) {
              adTengahContainer.innerHTML = `
                <a href="${iklanAktif.link_tujuan || '#'}" target="_blank" class="block w-full overflow-hidden rounded-xl shadow-sm hover:opacity-95 transition">
                  <img src="${gambarIklan}" alt="${iklanAktif.konten_teks || 'Sponsor'}" class="w-full h-auto max-h-48 object-cover" />
                </a>
              `;
            } else {
              adTengahContainer.innerHTML = `
                <a href="${iklanAktif.link_tujuan || '#'}" target="_blank" class="block w-full bg-emerald-50 border border-emerald-200 p-4 rounded-xl shadow-sm">
                  <span class="bg-emerald-600 text-white text-[9px] font-bold px-2 py-0.5 rounded uppercase">Sponsor Nusa-Media</span>
                  <h4 class="font-bold text-sm text-emerald-900 mt-1">${iklanAktif.konten_teks}</h4>
                </a>
              `;
            }
          } else {
            adTengahContainer.style.display = 'none';
          }
        } catch (error) {
          console.error("Gagal memuat data dinamis:", error);
          container.innerHTML = `<div class="text-center py-12"><p class="text-red-500 font-medium">Terjadi kesalahan koneksi server.</p></div>`;
        }
      }

      // Jalankan fungsi setelah komponen client aktif
      muatDataDinamis();
    </script>
  </body>
</html>
