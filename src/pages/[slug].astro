---
// 1. Fungsi Wajib Astro Statis: Daftarkan semua slug berita yang ada di Supabase
export async function getStaticPaths() {
  const SUPABASE_PROJECT_ID = "zmvlvzspjohrewjbtfxc";
  const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inptdmx2enNwam9ocmV3amJ0ZnhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMTM0MTAsImV4cCI6MjA5NDU4OTQxMH0.PtTVq_b4gLonRpNSbPYKncoXlGVS1lKaADy74dbhuSI";
  
  try {
    const response = await fetch(`https://${SUPABASE_PROJECT_ID}.supabase.co/rest/v1/berita?select=id`, {
      headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
    });
    const daftarBerita = await response.json();
    
    // Gunakan 'slug' sebagai penampung ID atau teks slug artikel
    return daftarBerita.map((berita) => ({
      params: { slug: berita.id.toString() },
    }));
  } catch (error) {
    console.error("Gagal membuat rute artikel:", error);
    return [];
  }
}

// 2. Ambil parameter slug dari URL
const { slug } = Astro.params;
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nusa Media - Detail Berita</title>
    <script src="https://tailwindcss.com"></script>
  </head>
  <body class="bg-[#FBFBFA] text-[#1A1A1A] antialiased">
    
    <div class="max-w-3xl mx-auto px-6 pt-10">
      <a href="/" class="text-xs font-bold text-blue-600 hover:text-blue-700 font-mono uppercase">
        ← Kembali ke Beranda
      </a>
    </div>

    <main class="max-w-3xl mx-auto px-6 py-8 space-y-6">
      <div id="kontenArtikel" class="space-y-4">
        <p class="text-xs text-gray-400 font-mono animate-pulse">Memuat konten berita secara aman...</p>
      </div>
    </main>

    <!-- KONEKSI CLIENT-SIDE KE SUPABASE (Hemat Kuota Vercel 100%) -->
    <script is:inline define:vars={{ slug }}>
      const container = document.getElementById('kontenArtikel');
      
      const SUPABASE_PROJECT_ID = "zmvlvzspjohrewjbtfxc";
      const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inptdmx2enNwam9ocmV3amJ0ZnhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMTM0MTAsImV4cCI6MjA5NDU4OTQxMH0.PtTVq_b4gLonRpNSbPYKncoXlGVS1lKaADy74dbhuSI";

      async function ambilDetailBerita() {
        try {
          const response = await fetch(`https://${SUPABASE_PROJECT_ID}.supabase.co/rest/v1/berita?id=eq.${slug}&select=*`, {
            headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
          });
          const data = await response.json();
          const berita = data[0];

          if (!berita) {
            container.innerHTML = `<p class="text-gray-500">Berita tidak ditemukan atau telah dihapus.</p>`;
            return;
          }

          container.innerHTML = `
            <span class="bg-zinc-900 text-white text-[9px] font-extrabold px-2.5 py-1 rounded-sm uppercase tracking-widest">
              ${berita.kategori || 'UMUM'}
            </span>
            <h1 class="text-3xl font-black text-gray-900 leading-tight">${berita.judul}</h1>
            <p class="text-xs text-gray-400 font-mono border-b pb-4">Oleh: ${berita.penulis || 'Redaksi'}</p>
            <img src="${berita.url_gambar}" class="w-full h-64 object-cover rounded-xl shadow-xs" />
            <p class="text-gray-800 text-sm leading-relaxed whitespace-pre-line pt-4">${berita.konten}</p>
          `;
        } catch (error) {
          container.innerHTML = `<p class="text-red-500">Gagal memuat artikel.</p>`;
        }
      }

      ambilDetailBerita();
    </script>
  </body>
</html>
