---
// 1. Wajib aktifkan prerender agar halaman statis cepat diakses pembaca
export const prerender = true;

// 2. Daftarkan semua parameter slug yang tersedia di database Supabase saat build
export async function getStaticPaths() {
  const SUPABASE_PROJECT_ID = "zmvlvzspjohrewjbtfxc";
  const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inptdmx2enNwam9ocmV3amJ0ZnhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMTM0MTAsImV4cCI6MjA5NDU4OTQxMH0.PtTVq_b4gLonRpNSbPYKncoXlGVS1lKaADy74dbhuSI";
  
  try {
    // Menarik kolom 'slug' dari tabel artikel Anda
    const response = await fetch(`https://${SUPABASE_PROJECT_ID}.supabase.co/rest/v1/artikel?select=slug`, {
      headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
    });
    const daftarArtikel = await response.json();
    
    if (!Array.isArray(daftarArtikel)) {
      console.error("Gagal memuat daftar slug dari Supabase:", daftarArtikel);
      return [];
    }

    // Filter data agar slug yang kosong atau null tidak menyebabkan error build
    return daftarArtikel
      .filter((artikel) => artikel.slug)
      .map((artikel) => ({
        params: { slug: artikel.slug.toString() },
      }));
  } catch (error) {
    console.error("Gagal membuat rute statis slug:", error);
    return [];
  }
}

// 3. Tangkap variabel slug dari URL halaman aktif
const { slug } = Astro.params;
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nusa Media - Detail Berita</title>
    <script src="https://tailwindcss.com"></script>
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com" rel="stylesheet">
    <style>
      body { font-family: 'Roboto', sans-serif; }
    </style>
  </head>
  <body class="bg-gray-100 text-gray-900 antialiased min-h-screen">
    
    <!-- Tombol Navigasi Kembali -->
    <div class="max-w-3xl mx-auto px-4 pt-10">
      <a href="/" class="text-xs font-bold text-red-600 hover:text-red-700 transition flex items-center gap-1">
        ← Kembali ke Beranda
      </a>
    </div>

    <!-- Wadah Konten Utama Berita -->
    <main class="max-w-3xl mx-auto px-4 py-6">
      <article id="kontenArtikel" class="bg-white rounded-lg border border-gray-200 p-6 sm:p-8 shadow-sm space-y-6">
        
        <!-- Animasi Skeleton Pemuatan Awal (Akan hilang jika data sukses di-fetch) -->
        <div class="space-y-4 animate-pulse">
          <div class="h-4 bg-gray-200 rounded w-1/4"></div>
          <div class="h-8 bg-gray-200 rounded w-3/4"></div>
          <div class="h-4 bg-gray-200 rounded w-1/2"></div>
          <div class="h-64 bg-gray-200 rounded-xl w-full"></div>
          <div class="space-y-2">
            <div class="h-4 bg-gray-200 rounded w-full"></div>
            <div class="h-4 bg-gray-200 rounded w-full"></div>
          </div>
        </div>

      </article>
    </main>

    <!-- KONEKSI CLIENT-SIDE LIVE KE SUPABASE BERDASARKAN SLUG -->
    <script is:inline define:vars={{ slug }}>
      const container = document.getElementById('kontenArtikel');
      
      const SUPABASE_PROJECT_ID = "zmvlvzspjohrewjbtfxc";
      const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inptdmx2enNwam9ocmV3amJ0ZnhjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzkwMTM0MTAsImV4cCI6MjA5NDU4OTQxMH0.PtTVq_b4gLonRpNSbPYKncoXlGVS1lKaADy74dbhuSI";

      async function ambilDetailBerita() {
        try {
          // 🛠️ MENCARI DATA BERDASARKAN KOLOM SLUG DI DATABASE
          const response = await fetch(`https://${SUPABASE_PROJECT_ID}.supabase.co/rest/v1/artikel?slug=eq.${slug}&select=*`, {
            headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': `Bearer ${SUPABASE_ANON_KEY}` }
          });
          const data = await response.json();
          
          // Mengambil objek pertama hasil penyaringan array database
          const berita = data && data.length > 0 ? data[0] : null;

          if (!berita) {
            container.innerHTML = `
              <div class="text-center py-12">
                <p class="text-gray-500 font-medium">Berita tidak ditemukan atau telah dihapus.</p>
                <a href="/" class="text-xs text-red-600 font-bold underline mt-2 inline-block">Kembali ke beranda</a>
              </div>
            `;
            return;
          }

          // Atur data teks & gambar cadangan jika properti kolom bernilai kosong
          const judulArtikel = berita.judul || 'Tanpa Judul';
          const kategoriArtikel = berita.kategori || 'UMUM';
          const penulisArtikel = berita.penulis || 'Redaksi';
          const kontenArtikel = berita.konten || 'Tidak ada isi konten.';
          const gambarArtikel = berita.image_url || berita.url_gambar || "https://unsplash.com";
          const tanggalArtikel = berita.created_at ? new Date(berita.created_at).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) : 'Baru saja';

          // Inject html data berita asli menggantikan element skeleton loading
          container.innerHTML = `
            <div class="space-y-4">
              <span class="bg-red-600 text-white text-[10px] font-bold px-2.5 py-1 rounded uppercase tracking-wider inline-block">
                ${kategoriArtikel}
              </span>
              <h1 class="text-2xl sm:text-3xl font-black text-gray-900 leading-tight">${judulArtikel}</h1>
              <div class="text-xs text-gray-400 border-b pb-4 flex flex-wrap gap-2 justify-between">
                <span>Penulis: <strong class="text-gray-700">${penulisArtikel}</strong></span>
                <span>📅 ${tanggalArtikel}</span>
              </div>
              <div class="overflow-hidden rounded-xl bg-slate-800">
                <img src="${gambarArtikel}" alt="${judulArtikel}" class="w-full h-auto max-h-96 object-cover mx-auto" />
              </div>
              <p class="text-gray-800 text-base leading-relaxed whitespace-pre-line pt-4 font-normal">${kontenArtikel}</p>
            </div>
          `;
        } catch (error) {
          container.innerHTML = `
            <div class="text-center py-12">
              <p class="text-red-500 font-medium">Gagal memuat artikel secara live. Silakan periksa koneksi Anda.</p>
            </div>
          `;
        }
      }

      // Jalankan fungsi fetch otomatis saat browser memuat halaman
      ambilDetailBerita();
    </script>
  </body>
</html>
