---
// File: src/pages/berita/[slug].astro
import { createClient } from '@supabase/supabase-js';

const { slug } = Astro.params;
const supabase = createClient(import.meta.env.SUPABASE_URL, import.meta.env.SUPABASE_ANON_KEY);

// 1. PROSES SIMPAN KOMENTAR BARU (Jika ada form yang disubmit)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const nama = formData.get("nama_pembaca");
    const isi = formData.get("isi_komentar");
    const beritaId = formData.get("berita_id");

    if (nama && isi && beritaId) {
      await supabase.from('komentar').insert([
        { nama_pembaca: nama, isi_komentar: isi, berita_id: beritaId }
      ]);
    }
  } catch (e) {
    console.error(e);
  }
}

// 2. TARIK DATA ARTIKEL
const { data: artikel } = await supabase
  .from('berita')
  .select('*, kategori(id, nama, slug), penulis(nama)')
  .eq('slug', slug)
  .single();

if (!artikel) return Astro.redirect('/404');

// 3. TARIK DAFTAR KOMENTAR UNTUK ARTIKEL INI
const { data: daftarKomentar } = await supabase
  .from('komentar')
  .select('*')
  .eq('berita_id', artikel.id)
  .order('created_at', { ascending: false });
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{artikel.judul}</title>
  </head>
  <body class="bg-[#111111] text-[#E5E5E5] font-sans antialiased">
    <main class="max-w-3xl mx-auto px-4 py-12">
      <!-- Navigasi Kategori Dinamis -->
      <a href={`/kategori/${artikel.kategori?.slug}`} class="text-xs font-bold text-white border-b border-white pb-1 uppercase hover:opacity-80">
        {artikel.kategori?.nama || 'Umum'}
      </a>
      
      <h1 class="text-3xl md:text-5xl font-serif font-bold text-white my-6">{artikel.judul}</h1>

      <!-- Tampilkan Gambar Cover Jika Ada URL-nya di Supabase -->
      {artikel.gambar_url && (
        <img src={artikel.gambar_url} alt={artikel.judul} class="w-full aspect-video object-cover mb-8 border border-[#2A2A2A]" />
      )}

      <p class="text-lg text-gray-300 italic mb-8 border-l-2 pl-4">{artikel.ringkasan}</p>
      <div class="text-gray-300 leading-relaxed whitespace-pre-line border-b border-[#2A2A2A] pb-12">{artikel.konten}</div>

      <!-- KANTONG KOMENTAR -->
      <section class="mt-12">
        <h3 class="text-lg font-bold text-white mb-6 font-serif">Komentar Pembaca ({daftarKomentar?.length || 0})</h3>
        
        <!-- Form Kirim Komentar -->
        <form method="POST" class="space-y-4 mb-8 bg-[#1A1A1A] p-6 border border-[#2A2A2A]">
          <input type="hidden" name="berita_id" value={artikel.id} />
          <div>
            <label class="block text-xs uppercase tracking-wider text-gray-400 mb-2">Nama Anda</label>
            <input type="text" name="nama_pembaca" required class="w-full bg-[#111111] border border-[#2A2A2A] px-4 py-2 text-sm text-white focus:outline-none focus:border-white" />
          </div>
          <div>
            <label class="block text-xs uppercase tracking-wider text-gray-400 mb-2">Isi Komentar</label>
            <textarea name="isi_komentar" rows="3" required class="w-full bg-[#111111] border border-[#2A2A2A] px-4 py-2 text-sm text-white focus:outline-none focus:border-white"></textarea>
          </div>
          <button type="submit" class="bg-white text-black px-4 py-2 text-xs uppercase font-black tracking-widest hover:bg-gray-200">Kirim Komentar</button>
        </form>

        <!-- Daftar Komentar Terkirim -->
        <div class="space-y-4">
          {daftarKomentar && daftarKomentar.map((kom) => (
            <div class="border-b border-[#2A2A2A] pb-4">
              <div class="flex justify-between text-xs text-gray-500 mb-1">
                <span class="font-bold text-gray-300">{kom.nama_pembaca}</span>
                <span>{new Date(kom.created_at).toLocaleDateString('id-ID')}</span>
              </div>
              <p class="text-sm text-gray-400">{kom.isi_komentar}</p>
            </div>
          ))}
        </div>
      </section>
    </main>
  </body>
</html>
