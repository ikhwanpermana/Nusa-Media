---
// src/pages/berita/[id].astro
export const prerender = false; // 🚀 STRATEGI TERBAIK: Mengaktifkan SSR agar setiap berita baru langsung aktif tanpa Error 404!

import { supabase } from '../../lib/supabase';

const { id } = Astro.params;

// 1. Ambil data detail berita spesifik secara real-time berdasarkan ID
const { data: berita, error } = await supabase
  .from('berita')
  .select('*')
  .eq('id', id)
  .maybeSingle();

// Jika berita tidak ditemukan di database Supabase, lempar ke halaman 404 resmi
if (error || !berita) {
  return Astro.redirect('/404');
}

// 2. VARIABEL SEO (DIPERBAIKI)
const judulSEO = `${berita.judul} | Nusa-Media`;
const deskripsiSEO = (berita.ringkasan || berita.isi_konten || '').substring(0, 160).replace(/<[^>]*>/g, '') + '...';
const gambarSEO = berita.gambar_url || "https://unsplash.com";

// PERBAIKAN 1: Menyempurnakan interpolasi string domain Nusa-Media yang benar
const urlSEO = `https://vercel.app{id}`;

// PERBAIKAN 2: Mengoreksi lambang ${} untuk fungsi encode API resmi share sosial media
const shareWA = `https://whatsapp.com{encodeURIComponent(berita.judul + ' - ' + urlSEO)}`;
const shareFB = `https://facebook.com{encodeURIComponent(urlSEO)}`;
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Standar -->
    <title>{judulSEO}</title>
    <meta name="description" content={deskripsiSEO} />
    <link rel="canonical" href={urlSEO} />
    
    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="article" />
    <meta property="og:url" content={urlSEO} />
    <meta property="og:title" content={judulSEO} />
    <meta property="og:description" content={deskripsiSEO} />
    <meta property="og:image" content={gambarSEO} />
    <meta property="og:site_name" content="Nusa-Media" />
    <meta property="article:published_time" content={berita.created_at} />
    <meta property="article:author" content={berita.penulis || 'Redaksi Nusa Media'} />

    <!-- Twitter / X -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={urlSEO} />
    <meta property="twitter:title" content={judulSEO} />
    <meta property="twitter:description" content={deskripsiSEO} />
    <meta property="twitter:image" content={gambarSEO} />

    <!-- PERBAIKAN 3: Memperbaiki tautan impor Google Fonts agar tipografi Roboto aktif -->
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <script src="https://tailwindcss.com"></script>
    <style>body { font-family: 'Roboto', sans-serif; }</style>
  </head>
  <body class="bg-gray-100 text-gray-900 min-h-screen">
    
    <main class="max-w-3xl mx-auto px-4 py-8">
      <a href="/" class="text-sm font-bold text-red-600 hover:underline inline-block mb-6">← Kembali ke Beranda</a>
      
      <article class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden p-6 md:p-8">
        <div class="mb-4">
          <span class="bg-red-600 text-white text-[10px] font-black uppercase px-2.5 py-1 rounded">
            {berita.kategori || 'Fokus'}
          </span>
          <span class="text-xs text-gray-400 ml-3">
            {berita.created_at ? new Date(berita.created_at).toLocaleDateString('id-ID', { dateStyle: 'long' }) : ''}
          </span>
        </div>

        <h1 class="text-2xl md:text-4xl font-black text-slate-900 leading-tight mb-4">
          {berita.judul}
        </h1>

        <div class="text-xs text-gray-500 pb-4 mb-4 flex flex-wrap justify-between items-center gap-4 border-b">
          <div>
            Penulis: <span class="font-bold text-gray-700">{berita.penulis || 'Redaksi Nusa Media'}</span>
          </div>
          
          <!-- SHARE BUTTONS -->
          <div class="flex items-center gap-2">
            <span class="text-[11px] font-bold text-gray-400 uppercase tracking-wider">Bagikan:</span>
            <a href={shareWA} target="_blank" rel="noopener noreferrer" class="bg-[#25D366] text-white text-xs font-bold px-3 py-1.5 rounded-full hover:opacity-90 transition flex items-center gap-1.5 shadow-sm">
              <!-- PERBAIKAN 4: Menyempurnakan ikon SVG resmi WhatsApp -->
              <svg xmlns="http://w3.org" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              WhatsApp
            </a>
            <a href={shareFB} target="_blank" rel="noopener noreferrer" class="bg-[#1877F2] text-white text-xs font-bold px-3 py-1.5 rounded-full hover:opacity-90 transition flex items-center gap-1.5 shadow-sm">
              <!-- PERBAIKAN 5: Menyempurnakan ikon SVG resmi Facebook -->
              <svg xmlns="http://w3.org" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook
            </a>
          </div>
        </div>

        <div class="w-full h-64 md:h-[400px] bg-slate-100 rounded-lg overflow-hidden mb-6 shadow-inner">
          <img src={gambarSEO} alt={berita.judul} class="w-full h-full object-cover" />
        </div>

        <div class="text-gray-800 text-base md:text-lg leading-relaxed whitespace-pre-line" set:html={berita.isi_konten}>
        </div>
      </article>
    </main>
    
  </body>
</html>
